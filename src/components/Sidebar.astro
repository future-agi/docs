---
/**
 * Sidebar Navigation
 * Tab-based navigation that changes based on current URL path
 * - Documentation, Integrations, Cookbooks, SDK Reference, API Reference
 * - Collapsible sections with nested items support
 */
import { tabNavigation, getActiveTab, type NavItem, type NavGroup } from '../lib/navigation';
import ThemeSwitcher from './ThemeSwitcher.astro';

const currentPath = Astro.url.pathname;
const activeTab = getActiveTab(currentPath);
const groups = activeTab?.groups || [];

// Check if any item in a group (or nested) matches the current path
function isGroupActive(group: NavGroup): boolean {
  return group.items.some(item => isItemOrChildActive(item));
}

// Check if an item or any of its children match the current path
function isItemOrChildActive(item: NavItem): boolean {
  if (isItemActive(item.href)) return true;
  if (item.items) {
    return item.items.some(child => isItemOrChildActive(child));
  }
  return false;
}

// Determine if a specific nav item is active
function isItemActive(itemHref: string | undefined): boolean {
  if (!itemHref) return false;
  // Normalize paths
  const normalizedCurrent = currentPath.replace(/\/$/, '') || '/';
  const normalizedHref = itemHref.replace(/\/$/, '') || '/';
  // Exact match
  if (normalizedHref === normalizedCurrent) return true;
  // Nested pages match (e.g., /docs/evaluate matches /docs/evaluate/metrics)
  if (normalizedHref !== '/' && normalizedHref !== '/docs' && normalizedCurrent.startsWith(normalizedHref + '/')) return true;
  return false;
}

// Icon paths for different group types
const iconPaths: Record<string, string> = {
  'rocket': 'M13 10V3L4 14h7v7l9-11h-7z',
  'table': 'M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z',
  'play': 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  'chart': 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  'zap': 'M13 10V3L4 14h7v7l9-11h-7z',
  'flask': 'M9 3v2m6-2v2M9 19h6m-3-11V3M5 21h14a2 2 0 002-2v-4a2 2 0 00-.586-1.414l-5-5A2 2 0 0014 8V3a1 1 0 00-1-1h-2a1 1 0 00-1 1v5a2 2 0 01-.586 1.414l-5 5A2 2 0 004 15v4a2 2 0 002 2z',
  'eye': 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
  'compass': 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
  'gauge': 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  'shield': 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'brain': 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  'plug': 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
  'book': 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  'search': 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  'code': 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  'check': 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  'robot': 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m18 0h-2M5 15H3m18 0h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z',
  'webhook': 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  'default': 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
};

function getIconPath(icon?: string): string {
  return iconPaths[icon || 'default'] || iconPaths.default;
}
---

<aside
  id="sidebar"
  class="fixed top-14 lg:top-24 left-0 bottom-0 w-64 border-r border-[var(--color-border-subtle)] bg-[var(--color-bg-primary)] transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out z-40 flex flex-col"
  transition:animate="none"
>
  <nav class="py-4 flex-1 overflow-y-auto hide-scrollbar">
    {groups.map((group, groupIndex) => {
      const isActive = isGroupActive(group);
      const iconPath = getIconPath(group.icon);

      return (
        <div class="mb-1" data-group={groupIndex}>
          {/* Group Header */}
          <button
            type="button"
            class="w-full flex items-center gap-2 px-4 py-2 text-left group"
            data-group-toggle={groupIndex}
            aria-expanded={isActive ? "true" : "false"}
          >
            <svg
              class:list={[
                "w-4 h-4 flex-shrink-0 transition-colors",
                isActive ? "text-[var(--color-accent-primary)]" : "text-[var(--color-text-tertiary)] group-hover:text-[var(--color-text-secondary)]"
              ]}
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconPath} />
            </svg>
            <span class:list={[
              "flex-1 text-sm font-medium transition-colors",
              isActive ? "text-[var(--color-text-primary)]" : "text-[var(--color-text-secondary)] group-hover:text-[var(--color-text-primary)]"
            ]}>
              {group.group}
            </span>
            <svg
              class:list={[
                "w-4 h-4 transition-transform duration-200",
                isActive ? "text-[var(--color-text-secondary)]" : "text-[var(--color-text-tertiary)]"
              ]}
              data-chevron={groupIndex}
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              style={isActive ? "transform: rotate(180deg)" : ""}
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          {/* Group Items */}
          <ul
            class:list={[
              "overflow-hidden transition-all duration-200",
              isActive ? "max-h-[2000px] opacity-100" : "max-h-0 opacity-0"
            ]}
            data-group-items={groupIndex}
          >
            {group.items.map((item) => {
              const itemActive = isItemActive(item.href);
              const hasChildren = item.items && item.items.length > 0;
              const childrenActive = hasChildren && item.items?.some(child => isItemOrChildActive(child));

              return (
                <li>
                  {hasChildren ? (
                    // Item with nested children
                    <div class="nested-group" data-nested-active={childrenActive ? "true" : "false"}>
                      <button
                        type="button"
                        class:list={[
                          "w-full flex items-center gap-2 pl-10 pr-4 py-1.5 text-sm transition-colors text-left",
                          childrenActive
                            ? "text-[var(--color-text-primary)] font-medium"
                            : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]"
                        ]}
                        data-nested-toggle
                      >
                        <span class="flex-1">{item.title}</span>
                        <svg
                          class:list={[
                            "w-3 h-3 transition-transform duration-200",
                            childrenActive ? "" : ""
                          ]}
                          data-nested-chevron
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                          style={childrenActive ? "transform: rotate(180deg)" : ""}
                        >
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                      </button>
                      <ul
                        class:list={[
                          "overflow-hidden transition-all duration-200",
                          childrenActive ? "max-h-[2000px] opacity-100" : "max-h-0 opacity-0"
                        ]}
                        data-nested-items
                      >
                        {item.items?.map((child) => {
                          const childActive = isItemActive(child.href);
                          return (
                            <li>
                              <a
                                href={child.href}
                                class:list={[
                                  "flex items-center gap-2 pl-14 pr-4 py-1.5 text-sm transition-colors",
                                  childActive
                                    ? "text-[var(--color-accent-primary)] bg-[var(--color-accent-primary)]/10 font-medium"
                                    : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)]"
                                ]}
                              >
                                <span class="flex-1">{child.title}</span>
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  ) : (
                    // Simple item without children
                    <a
                      href={item.href}
                      class:list={[
                        "flex items-center gap-2 pl-10 pr-4 py-1.5 text-sm transition-colors",
                        itemActive
                          ? "text-[var(--color-accent-primary)] bg-[var(--color-accent-primary)]/10 font-medium"
                          : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)]"
                      ]}
                    >
                      <span class="flex-1">{item.title}</span>
                      {item.badge && (
                        <span class:list={[
                          "px-1.5 py-0.5 text-[10px] font-medium rounded",
                          item.badge === 'New'
                            ? "bg-[var(--color-success)]/10 text-[var(--color-success)]"
                            : "bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]"
                        ]}>
                          {item.badge}
                        </span>
                      )}
                    </a>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      );
    })}
  </nav>

  {/* Footer - Compact Theme Switcher */}
  <div class="flex-shrink-0 px-3 py-2 border-t border-[var(--color-border-subtle)] bg-[var(--color-bg-primary)]">
    <ThemeSwitcher />
  </div>
</aside>

{/* Mobile overlay */}
<div
  id="sidebar-overlay"
  class="fixed inset-0 bg-black/60 z-30 lg:hidden hidden"
></div>

<script>
  // Collapsible groups
  document.querySelectorAll('[data-group-toggle]').forEach(button => {
    button.addEventListener('click', () => {
      const groupIndex = button.getAttribute('data-group-toggle');
      const items = document.querySelector(`[data-group-items="${groupIndex}"]`);
      const chevron = document.querySelector(`[data-chevron="${groupIndex}"]`);

      if (items && chevron) {
        const isOpen = items.classList.contains('max-h-[2000px]');

        if (isOpen) {
          items.classList.remove('max-h-[2000px]', 'opacity-100');
          items.classList.add('max-h-0', 'opacity-0');
          (chevron as HTMLElement).style.transform = '';
          button.setAttribute('aria-expanded', 'false');
        } else {
          items.classList.remove('max-h-0', 'opacity-0');
          items.classList.add('max-h-[2000px]', 'opacity-100');
          (chevron as HTMLElement).style.transform = 'rotate(180deg)';
          button.setAttribute('aria-expanded', 'true');
        }
      }
    });
  });

  // Nested item toggles
  document.querySelectorAll('[data-nested-toggle]').forEach(button => {
    button.addEventListener('click', () => {
      const parent = button.closest('.nested-group');
      const items = parent?.querySelector('[data-nested-items]');
      const chevron = parent?.querySelector('[data-nested-chevron]');

      if (items && chevron) {
        const isOpen = items.classList.contains('max-h-[2000px]');

        if (isOpen) {
          items.classList.remove('max-h-[2000px]', 'opacity-100');
          items.classList.add('max-h-0', 'opacity-0');
          (chevron as HTMLElement).style.transform = '';
        } else {
          items.classList.remove('max-h-0', 'opacity-0');
          items.classList.add('max-h-[2000px]', 'opacity-100');
          (chevron as HTMLElement).style.transform = 'rotate(180deg)';
        }
      }
    });
  });

  // Mobile sidebar toggle
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');

  overlay?.addEventListener('click', () => {
    sidebar?.classList.add('-translate-x-full');
    sidebar?.classList.remove('translate-x-0');
    overlay?.classList.add('hidden');
  });
</script>
