---
/**
 * Floating AI Chat Widget
 * Bottom-right floating bubble → resizable chat popup → fullscreen mode
 */
---

<!-- Chat popup -->
<div
  id="ai-chat-popup"
  class="fixed z-50 rounded-2xl border border-[var(--color-border-default)] shadow-2xl shadow-black/30 flex-col overflow-hidden hidden"
  style="background: #111111; bottom: 24px; right: 24px; width: 380px; height: 520px;"
>
  <!-- Resize handle (top-left corner) -->
  <div id="ai-resize-handle" class="absolute top-0 left-0 w-4 h-4 cursor-nwse-resize z-10" style="cursor: nw-resize;">
    <svg class="w-3 h-3 text-[var(--color-text-muted)] opacity-0 hover:opacity-100 transition-opacity m-0.5 rotate-90" viewBox="0 0 24 24" fill="currentColor">
      <circle cx="4" cy="4" r="2"/><circle cx="12" cy="4" r="2"/><circle cx="4" cy="12" r="2"/>
    </svg>
  </div>

  <!-- Header -->
  <div class="flex items-center gap-2.5 px-4 py-2.5 border-b border-[var(--color-border-subtle)] flex-shrink-0" style="background: #161616;">
    <svg class="w-4 h-4 text-[var(--color-accent-primary)] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span class="text-sm font-semibold text-[var(--color-text-primary)] flex-1">AI Assistant</span>
    <span class="px-1.5 py-0.5 text-[10px] font-medium rounded bg-[var(--color-accent-primary)]/15 text-[var(--color-accent-primary)]">Beta</span>

    <!-- Fullscreen toggle -->
    <button
      id="ai-fullscreen-btn"
      class="p-1 rounded-md text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] transition-colors cursor-pointer"
      title="Toggle fullscreen"
    >
      <!-- Expand icon -->
      <svg id="ai-fs-expand" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <!-- Shrink icon (hidden) -->
      <svg id="ai-fs-shrink" class="w-3.5 h-3.5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 14h6v6M20 10h-6V4M14 10l7-7M3 21l7-7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    <!-- Close -->
    <button
      id="ai-popup-close"
      class="p-1 rounded-md text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] transition-colors cursor-pointer"
      title="Close"
    >
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </div>

  <!-- Messages -->
  <div id="ai-widget-messages" class="flex-1 overflow-y-auto px-4 py-4 hide-scrollbar">
    <p class="text-xs text-[var(--color-text-muted)] text-center mb-4 leading-relaxed">
      Ask me anything about FutureAGI, evaluations, tracing, or our SDK.
    </p>
    <div id="ai-widget-quick" class="space-y-1.5">
      <button class="ai-wq w-full text-left px-3 py-2.5 text-[13px] border border-[var(--color-border-subtle)] rounded-lg text-[var(--color-text-secondary)] hover:border-[var(--color-border-default)] hover:text-[var(--color-text-primary)] transition-all cursor-pointer" style="background: #161616;" data-q="How do I evaluate an LLM?">How do I evaluate an LLM?</button>
      <button class="ai-wq w-full text-left px-3 py-2.5 text-[13px] border border-[var(--color-border-subtle)] rounded-lg text-[var(--color-text-secondary)] hover:border-[var(--color-border-default)] hover:text-[var(--color-text-primary)] transition-all cursor-pointer" style="background: #161616;" data-q="How do I set up tracing?">How do I set up tracing?</button>
      <button class="ai-wq w-full text-left px-3 py-2.5 text-[13px] border border-[var(--color-border-subtle)] rounded-lg text-[var(--color-text-secondary)] hover:border-[var(--color-border-default)] hover:text-[var(--color-text-primary)] transition-all cursor-pointer" style="background: #161616;" data-q="What metrics are available?">What metrics are available?</button>
    </div>
  </div>

  <!-- Input -->
  <div class="px-4 py-3 border-t border-[var(--color-border-subtle)] flex-shrink-0" style="background: #161616;">
    <div class="flex items-end gap-2 border border-[var(--color-border-subtle)] rounded-xl px-3 py-2.5 focus-within:border-[var(--color-border-accent)] transition-colors" style="background: #111111;">
      <textarea
        id="ai-widget-input"
        placeholder="Ask a question..."
        rows="1"
        class="flex-1 bg-transparent border-none resize-none text-[13px] text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] leading-snug"
        style="min-height: 20px; max-height: 80px; outline: none !important; box-shadow: none !important;"
      ></textarea>
      <button id="ai-widget-send" class="w-7 h-7 flex items-center justify-center rounded-lg flex-shrink-0 cursor-pointer hover:opacity-90 transition-opacity" style="background: #8b5cf6;">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="white" stroke="none">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
        </svg>
      </button>
    </div>
    <p class="text-[10px] text-[var(--color-text-muted)] text-center mt-2">Powered by AI</p>
  </div>
</div>

<script is:inline>
(function() {
  function setupWidget() {
    var popup = document.getElementById('ai-chat-popup');
    var closeBtn = document.getElementById('ai-popup-close');
    var fsBtn = document.getElementById('ai-fullscreen-btn');
    var fsExpand = document.getElementById('ai-fs-expand');
    var fsShrink = document.getElementById('ai-fs-shrink');
    var resizeHandle = document.getElementById('ai-resize-handle');
    var input = document.getElementById('ai-widget-input');
    var sendBtn = document.getElementById('ai-widget-send');
    var messagesEl = document.getElementById('ai-widget-messages');
    var quickWrap = document.getElementById('ai-widget-quick');
    var quickBtns = document.querySelectorAll('.ai-wq');

    if (!popup) return;
    if (popup._wl) return;
    popup._wl = true;

    var isOpen = false;
    var isFullscreen = false;

    // Default (non-fullscreen) size and position
    var defaultStyle = { bottom: '24px', right: '24px', width: '380px', height: '520px', top: 'auto', left: 'auto', borderRadius: '16px' };
    var MIN_W = 320;
    var MIN_H = 360;

    function applyDefault() {
      popup.style.bottom = defaultStyle.bottom;
      popup.style.right = defaultStyle.right;
      popup.style.width = defaultStyle.width;
      popup.style.height = defaultStyle.height;
      popup.style.top = defaultStyle.top;
      popup.style.left = defaultStyle.left;
      popup.style.borderRadius = defaultStyle.borderRadius;
    }

    function open() {
      isOpen = true;
      applyDefault();
      popup.classList.remove('hidden');
      popup.classList.add('flex');
      popup.style.opacity = '0';
      popup.style.transform = 'translateY(8px) scale(0.97)';
      popup.offsetHeight;
      popup.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
      popup.style.opacity = '1';
      popup.style.transform = 'translateY(0) scale(1)';
      if (input) setTimeout(function() { input.focus(); }, 100);
    }

    function close() {
      if (isFullscreen) exitFullscreen();
      isOpen = false;
      popup.style.opacity = '0';
      popup.style.transform = 'translateY(8px) scale(0.97)';
      setTimeout(function() {
        popup.classList.add('hidden');
        popup.classList.remove('flex');
        popup.style.transition = '';
      }, 200);
    }

    function enterFullscreen() {
      isFullscreen = true;
      // Save current size for restore
      defaultStyle.width = popup.style.width;
      defaultStyle.height = popup.style.height;
      popup.style.transition = 'all 0.25s ease';
      popup.style.top = '0';
      popup.style.left = '0';
      popup.style.right = '0';
      popup.style.bottom = '0';
      popup.style.width = '100%';
      popup.style.height = '100%';
      popup.style.borderRadius = '0';
      fsExpand.classList.add('hidden');
      fsShrink.classList.remove('hidden');
      setTimeout(function() { popup.style.transition = ''; }, 250);
    }

    function exitFullscreen() {
      isFullscreen = false;
      popup.style.transition = 'all 0.25s ease';
      popup.style.top = 'auto';
      popup.style.left = 'auto';
      popup.style.right = defaultStyle.right;
      popup.style.bottom = defaultStyle.bottom;
      popup.style.width = defaultStyle.width;
      popup.style.height = defaultStyle.height;
      popup.style.borderRadius = defaultStyle.borderRadius;
      fsShrink.classList.add('hidden');
      fsExpand.classList.remove('hidden');
      setTimeout(function() { popup.style.transition = ''; }, 250);
    }

    if (closeBtn) closeBtn.addEventListener('click', close);
    if (fsBtn) fsBtn.addEventListener('click', function() { isFullscreen ? exitFullscreen() : enterFullscreen(); });

    window.openAiChat = function() { if (!isOpen) open(); };
    window.closeAiChat = function() { if (isOpen) close(); };

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && isOpen) {
        if (isFullscreen) { exitFullscreen(); } else { close(); }
      }
    });

    // --- Resize from top-left corner ---
    if (resizeHandle) {
      var resizing = false;
      var startX, startY, startW, startH, startRight, startBottom;

      resizeHandle.addEventListener('mousedown', function(e) {
        if (isFullscreen) return;
        e.preventDefault();
        resizing = true;
        startX = e.clientX;
        startY = e.clientY;
        startW = popup.offsetWidth;
        startH = popup.offsetHeight;
        startRight = parseInt(popup.style.right) || 24;
        startBottom = parseInt(popup.style.bottom) || 88;
        document.body.style.userSelect = 'none';
        document.body.style.cursor = 'nw-resize';
      });

      document.addEventListener('mousemove', function(e) {
        if (!resizing) return;
        var dx = startX - e.clientX; // drag left = bigger width
        var dy = startY - e.clientY; // drag up = bigger height
        var newW = Math.max(MIN_W, startW + dx);
        var newH = Math.max(MIN_H, startH + dy);
        popup.style.width = newW + 'px';
        popup.style.height = newH + 'px';
      });

      document.addEventListener('mouseup', function() {
        if (resizing) {
          resizing = false;
          document.body.style.userSelect = '';
          document.body.style.cursor = '';
          // Save new size as default
          defaultStyle.width = popup.style.width;
          defaultStyle.height = popup.style.height;
        }
      });
    }

    // --- Auto-resize textarea ---
    if (input) {
      input.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 80) + 'px';
      });
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          sendMessage();
        }
      });
    }

    if (sendBtn) sendBtn.addEventListener('click', sendMessage);

    quickBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (input) {
          input.value = this.getAttribute('data-q');
          sendMessage();
        }
      });
    });

    function sendMessage() {
      var msg = input ? input.value.trim() : '';
      if (!msg) return;
      var welcome = messagesEl.querySelector('p');
      if (welcome) welcome.style.display = 'none';
      if (quickWrap) quickWrap.style.display = 'none';
      addMsg(msg, 'user');
      input.value = '';
      input.style.height = 'auto';

      var typingEl = document.createElement('div');
      typingEl.className = 'flex justify-start mb-2';
      typingEl.innerHTML = '<div class="ai-w-bubble ai-w-typing"><span></span><span></span><span></span></div>';
      messagesEl.appendChild(typingEl);
      messagesEl.scrollTop = messagesEl.scrollHeight;

      setTimeout(function() {
        typingEl.remove();
        addMsg("I'm a placeholder response. Connect an AI provider (OpenAI, Anthropic) to enable real answers.", 'assistant');
      }, 1500);
    }

    function addMsg(text, role) {
      var wrap = document.createElement('div');
      wrap.className = 'flex mb-2 ' + (role === 'user' ? 'justify-end' : 'justify-start');
      var bubble = document.createElement('div');
      bubble.className = role === 'user' ? 'ai-w-user' : 'ai-w-bubble';
      bubble.textContent = text;
      wrap.appendChild(bubble);
      messagesEl.appendChild(wrap);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }
  }

  setupWidget();
  document.addEventListener('astro:page-load', setupWidget);
})();
</script>

<style is:global>
  .ai-w-user {
    max-width: 80%;
    padding: 8px 14px;
    border-radius: 16px 16px 4px 16px;
    font-size: 13px;
    line-height: 1.5;
    background: var(--color-accent-primary);
    color: white;
    white-space: pre-wrap;
  }
  .ai-w-bubble {
    max-width: 80%;
    padding: 8px 14px;
    border-radius: 16px 16px 16px 4px;
    font-size: 13px;
    line-height: 1.5;
    background: #1a1a1a;
    color: var(--color-text-primary);
    white-space: pre-wrap;
  }
  .ai-w-typing {
    display: flex;
    gap: 4px;
    padding: 12px 16px;
  }
  .ai-w-typing span {
    width: 5px;
    height: 5px;
    background: var(--color-text-muted);
    border-radius: 50%;
    animation: aiWDot 1.4s infinite ease-in-out;
  }
  .ai-w-typing span:nth-child(2) { animation-delay: 0.2s; }
  .ai-w-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes aiWDot {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-3px); opacity: 1; }
  }
</style>
