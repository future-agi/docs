---
interface Props {
  class?: string;
  size?: number;
}

const { class: className = '', size = 32 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class:list={["flex-shrink-0", className]}
>
  <defs>
    <linearGradient id="logo-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#3b82f6" />
      <stop offset="100%" stop-color="#8b5cf6" />
    </linearGradient>
  </defs>

  <!-- Abstract AI brain/neural network symbol -->
  <rect width="32" height="32" rx="8" fill="url(#logo-gradient)" />

  <!-- Neural nodes -->
  <circle cx="10" cy="10" r="2" fill="white" opacity="0.9" />
  <circle cx="22" cy="10" r="2" fill="white" opacity="0.9" />
  <circle cx="16" cy="16" r="2.5" fill="white" />
  <circle cx="10" cy="22" r="2" fill="white" opacity="0.9" />
  <circle cx="22" cy="22" r="2" fill="white" opacity="0.9" />

  <!-- Connections -->
  <path d="M12 10L14 14M20 10L18 14M12 22L14 18M20 22L18 18" stroke="white" stroke-width="1.5" opacity="0.6" stroke-linecap="round" />
</svg>
