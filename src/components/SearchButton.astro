---
/**
 * Search Button Component
 * A static search trigger that opens Inkeep modal
 * No flicker on page navigation
 */
---

<button
  type="button"
  id="search-trigger"
  class="search-button"
  aria-label="Search documentation"
  transition:persist="search-button"
>
  <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
  </svg>
  <span class="search-text">Search...</span>
  <kbd class="search-kbd">
    <span class="kbd-key">⌘</span>K
  </kbd>
</button>

<script is:inline>
  (function() {
    function getEffectiveTheme() {
      var stored = localStorage.getItem('theme');
      if (stored === 'light') return 'light';
      if (stored === 'dark') return 'dark';
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function getInkeepConfig(colorMode) {
      return {
        baseSettings: {
          apiKey: "YOUR_INKEEP_API_KEY",
          organizationDisplayName: "Future AGI",
          primaryBrandColor: colorMode === 'light' ? "#2563EB" : "#60A5FA",
          theme: {
            colorMode: {
              forcedColorMode: colorMode
            }
          }
        },
        searchSettings: {
          placeholder: "Search documentation...",
        },
        aiChatSettings: {
          chatSubjectName: "Future AGI",
          quickQuestions: [
            "How do I evaluate an LLM?",
            "How do I set up tracing?",
            "What metrics are available?",
          ]
        },
        modalSettings: {
          isShortcutKeyEnabled: true,
          shortcutKey: "k",
        }
      };
    }

    function initInkeep() {
      if (typeof Inkeep === 'undefined') {
        setTimeout(initInkeep, 100);
        return;
      }

      // Only initialize once globally
      if (window.__inkeepWidget) {
        return;
      }

      var colorMode = getEffectiveTheme();
      var config = getInkeepConfig(colorMode);

      // Use ChatButton which creates a modal-only experience
      window.__inkeepWidget = Inkeep.ChatButton({
        ...config,
        chatButtonSettings: {
          // Hide the floating button, we'll trigger via our custom button
          chatButtonType: "ICON_TEXT",
          chatButtonBgColor: "transparent",
        }
      });

      window.__inkeepTheme = colorMode;
    }

    function setupSearchButton() {
      var searchTrigger = document.getElementById('search-trigger');

      // Click handler for our custom button
      if (searchTrigger && !searchTrigger._hasListener) {
        searchTrigger._hasListener = true;
        searchTrigger.addEventListener('click', function() {
          // Try to open Inkeep modal
          if (window.__inkeepWidget && window.__inkeepWidget.open) {
            window.__inkeepWidget.open();
          } else {
            // Fallback: simulate Cmd+K
            var event = new KeyboardEvent('keydown', {
              key: 'k',
              code: 'KeyK',
              metaKey: true,
              bubbles: true
            });
            document.dispatchEvent(event);
          }
        });
      }
    }

    // Listen for theme changes (only add once)
    if (!window.__inkeepThemeListenerAdded) {
      window.addEventListener('theme-change', function(event) {
        // Reinitialize Inkeep with new theme
        if (window.__inkeepWidget && typeof Inkeep !== 'undefined') {
          window.__inkeepWidget = null;
          var colorMode = event.detail.effectiveTheme;
          var config = getInkeepConfig(colorMode);
          window.__inkeepWidget = Inkeep.ChatButton({
            ...config,
            chatButtonSettings: {
              chatButtonType: "ICON_TEXT",
              chatButtonBgColor: "transparent",
            }
          });
          window.__inkeepTheme = colorMode;
        }
      });
      window.__inkeepThemeListenerAdded = true;
    }

    // Initialize on first load
    function init() {
      initInkeep();
      setupSearchButton();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    // Handle View Transitions - only re-setup button, not Inkeep
    document.addEventListener('astro:page-load', setupSearchButton);
  })();
</script>

<style>
  .search-button {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    min-width: 280px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-default);
    border-radius: 0.5rem;
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .search-button:hover {
    border-color: var(--color-border-accent);
    background: var(--color-bg-hover);
  }

  .search-button:focus {
    outline: none;
    border-color: var(--color-accent-primary);
    box-shadow: 0 0 0 2px var(--selection-bg);
  }

  .search-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .search-text {
    flex: 1;
    text-align: left;
  }

  .search-kbd {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border-default);
    border-radius: 0.25rem;
    color: var(--color-text-muted);
  }

  .kbd-key {
    font-size: 0.875rem;
  }

  @media (max-width: 640px) {
    .search-button {
      min-width: auto;
      padding: 0.5rem;
    }

    .search-text,
    .search-kbd {
      display: none;
    }
  }
</style>
