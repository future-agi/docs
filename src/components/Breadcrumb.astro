---
const currentPath = Astro.url.pathname;
const pathParts = currentPath.split('/').filter(Boolean);

function toTitleCase(str: string) {
  return str
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const breadcrumbs = pathParts.map((part, index) => ({
  label: toTitleCase(part),
  href: '/' + pathParts.slice(0, index + 1).join('/'),
  isLast: index === pathParts.length - 1,
}));
---

<nav class="flex items-center gap-2 text-sm mb-6" aria-label="Breadcrumb">
  <a
    href="/"
    class="text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
    </svg>
  </a>

  {breadcrumbs.map((crumb) => (
    <>
      <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      {crumb.isLast ? (
        <span class="text-[var(--color-text-secondary)] font-medium">{crumb.label}</span>
      ) : (
        <a
          href={crumb.href}
          class="text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)] transition-colors"
        >
          {crumb.label}
        </a>
      )}
    </>
  ))}
</nav>
