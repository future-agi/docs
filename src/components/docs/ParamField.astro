---
/**
 * ParamField Component
 * For API documentation parameters
 */
interface Props {
  path?: string;
  query?: string;
  body?: string;
  header?: string;
  name?: string;
  type?: string;
  required?: boolean;
  default?: string;
}

const { path, query, body, header, name, type, required } = Astro.props;
const paramName = path || query || body || header || name;
---

<div class="my-4 p-4 border-l-2 border-[var(--color-border-default)] bg-[var(--color-bg-tertiary)] rounded-r">
  <div class="flex items-center gap-2 mb-2">
    <code class="text-sm font-mono text-[var(--color-accent-primary)]">{paramName}</code>
    {type && <span class="text-xs text-[var(--color-text-tertiary)]">{type}</span>}
    {required && <span class="text-xs text-red-500">Required</span>}
  </div>
  <div class="text-sm text-[var(--color-text-secondary)]">
    <slot />
  </div>
</div>
