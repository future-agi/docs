---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="step-item">
  <h4 class="font-semibold text-[var(--color-text-primary)] mb-2">{title}</h4>
  <div class="text-sm text-[var(--color-text-secondary)] [&>p]:mb-2 [&>p:last-child]:mb-0">
    <slot />
  </div>
</div>
