---
/**
 * CardGrid Component
 * Alias for CardGroup for Mintlify compatibility
 */
interface Props {
  cols?: 2 | 3 | 4;
}

const { cols = 2 } = Astro.props;
---

<div class:list={[
  "grid gap-4 my-6",
  cols === 2 ? "sm:grid-cols-2" :
  cols === 3 ? "sm:grid-cols-2 lg:grid-cols-3" :
  "sm:grid-cols-2 lg:grid-cols-4"
]}>
  <slot />
</div>
