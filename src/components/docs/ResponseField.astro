---
/**
 * ResponseField Component
 * For API documentation responses
 */
interface Props {
  name: string;
  type?: string;
  required?: boolean;
}

const { name, type, required } = Astro.props;
---

<div class="my-4 p-4 border-l-2 border-[var(--color-border-default)] bg-[var(--color-bg-tertiary)] rounded-r">
  <div class="flex items-center gap-2 mb-2">
    <code class="text-sm font-mono text-[var(--color-accent-primary)]">{name}</code>
    {type && <span class="text-xs text-[var(--color-text-tertiary)]">{type}</span>}
    {required && <span class="text-xs text-red-500">Required</span>}
  </div>
  <div class="text-sm text-[var(--color-text-secondary)]">
    <slot />
  </div>
</div>
