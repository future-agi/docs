---
/**
 * API Playground Component
 * Interactive API testing interface similar to Mintlify
 */
interface Parameter {
  name: string;
  in: 'path' | 'query' | 'header' | 'body';
  required?: boolean;
  type?: string;
  description?: string;
  schema?: any;
  example?: any;
}

interface Props {
  method: 'GET' | 'POST' | 'PUT' | 'DELETE' | 'PATCH';
  endpoint: string;
  baseUrl?: string;
  parameters?: Parameter[];
  requestBody?: any;
  headers?: { name: string; value: string; required?: boolean }[];
  contentType?: 'json' | 'multipart';
  hiddenFields?: Record<string, string>;
}

const {
  method,
  endpoint,
  baseUrl = 'https://api.futureagi.com',
  parameters = [],
  requestBody,
  headers = [],
  contentType = 'json',
  hiddenFields = {}
} = Astro.props;

// For multipart forms, separate file fields from text fields
const isMultipart = contentType === 'multipart';
const multipartFields = isMultipart && requestBody
  ? Object.entries(requestBody).map(([key, value]) => ({
      name: key,
      isFile: value === '(binary)',
      defaultValue: value === '(binary)' ? '' : String(value),
    }))
  : [];

const methodColors: Record<string, { bg: string; text: string; border: string }> = {
  GET: { bg: 'bg-emerald-500/10', text: 'text-emerald-500', border: 'border-emerald-500/30' },
  POST: { bg: 'bg-blue-500/10', text: 'text-blue-500', border: 'border-blue-500/30' },
  PUT: { bg: 'bg-amber-500/10', text: 'text-amber-500', border: 'border-amber-500/30' },
  DELETE: { bg: 'bg-red-500/10', text: 'text-red-500', border: 'border-red-500/30' },
  PATCH: { bg: 'bg-purple-500/10', text: 'text-purple-500', border: 'border-purple-500/30' },
};

const colors = methodColors[method] || methodColors.GET;

const pathParams = parameters.filter(p => p.in === 'path');
const queryParams = parameters.filter(p => p.in === 'query');
const headerParams = parameters.filter(p => p.in === 'header');

// Generate unique ID for this playground instance
const playgroundId = `playground-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="api-playground my-6 border border-[var(--color-border-default)] rounded-lg overflow-hidden bg-[var(--color-bg-secondary)]" data-playground-id={playgroundId}>
  <!-- Header with method and endpoint -->
  <div class={`flex items-center gap-3 px-4 py-3 border-b border-[var(--color-border-default)] ${colors.bg}`}>
    <span class={`px-2 py-1 text-xs font-bold rounded ${colors.bg} ${colors.text} border ${colors.border}`}>
      {method}
    </span>
    <code class="text-sm text-[var(--color-text-primary)] font-mono flex-1">
      {baseUrl}{endpoint}
    </code>
    <button
      type="button"
      class="try-it-btn px-3 py-1.5 text-xs font-medium rounded-md bg-[var(--color-text-primary)] text-[var(--color-bg-primary)] hover:shadow-[0_0_15px_rgba(250,250,250,0.2)] transition-all"
      data-playground={playgroundId}
    >
      Try It
    </button>
  </div>

  <!-- Parameters Section -->
  <div class="p-4 space-y-4">
    <!-- Authentication -->
    <div class="space-y-2">
      <label class="block text-sm font-medium text-[var(--color-text-primary)]">
        Authentication
      </label>
      <div class="space-y-2">
        <div class="flex gap-2">
          <span class="w-28 px-3 py-2 text-sm bg-[var(--color-bg-tertiary)] border border-[var(--color-border-default)] rounded-l-md text-[var(--color-text-secondary)]">
            X-Api-Key
          </span>
          <input
            type="password"
            class="api-key-input flex-1 px-3 py-2 text-sm bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] rounded-r-md text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-primary)]/50 focus:border-[var(--color-accent-primary)]"
            placeholder="Enter your API key"
            data-param="api-key"
          />
        </div>
        <div class="flex gap-2">
          <span class="w-28 px-3 py-2 text-sm bg-[var(--color-bg-tertiary)] border border-[var(--color-border-default)] rounded-l-md text-[var(--color-text-secondary)]">
            X-Secret-Key
          </span>
          <input
            type="password"
            class="secret-key-input flex-1 px-3 py-2 text-sm bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] rounded-r-md text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-primary)]/50 focus:border-[var(--color-accent-primary)]"
            placeholder="Enter your secret key"
            data-param="secret-key"
          />
        </div>
      </div>
    </div>

    <!-- Path Parameters -->
    {pathParams.length > 0 && (
      <div class="space-y-2">
        <label class="block text-sm font-medium text-[var(--color-text-primary)]">
          Path Parameters
        </label>
        <div class="space-y-2">
          {pathParams.map(param => (
            <div class="flex items-center gap-2">
              <span class="w-32 text-sm text-[var(--color-text-secondary)]">
                {param.name}
                {param.required && <span class="text-red-500">*</span>}
              </span>
              <input
                type="text"
                class="path-param flex-1 px-3 py-2 text-sm bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] rounded-md text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-primary)]/50"
                placeholder={param.description || param.name}
                data-param-name={param.name}
                data-param-type="path"
              />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Query Parameters -->
    {queryParams.length > 0 && (
      <div class="space-y-2">
        <label class="block text-sm font-medium text-[var(--color-text-primary)]">
          Query Parameters
        </label>
        <div class="space-y-2">
          {queryParams.map(param => (
            <div class="flex items-center gap-2">
              <span class="w-32 text-sm text-[var(--color-text-secondary)]">
                {param.name}
                {param.required && <span class="text-red-500">*</span>}
              </span>
              <input
                type="text"
                class="query-param flex-1 px-3 py-2 text-sm bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] rounded-md text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-primary)]/50"
                placeholder={param.description || param.name}
                data-param-name={param.name}
                data-param-type="query"
              />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Request Body (JSON) -->
    {requestBody && !isMultipart && (
      <div class="space-y-2">
        <label class="block text-sm font-medium text-[var(--color-text-primary)]">
          Request Body
        </label>
        <textarea
          class="request-body w-full h-48 px-3 py-2 text-sm font-mono bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] rounded-md text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-primary)]/50 resize-y"
          placeholder="Enter JSON request body"
          data-param-type="body"
        >{JSON.stringify(requestBody, null, 2)}</textarea>
      </div>
    )}

    <!-- Request Body (Multipart Form) -->
    {isMultipart && multipartFields.length > 0 && (
      <div class="space-y-2">
        <label class="block text-sm font-medium text-[var(--color-text-primary)]">
          Request Body <span class="text-xs text-[var(--color-text-muted)] font-normal ml-1">multipart/form-data</span>
        </label>
        <div class="space-y-3">
          {multipartFields.map(field => (
            <div class="flex items-center gap-2">
              <span class="w-40 text-sm text-[var(--color-text-secondary)] shrink-0">
                {field.name}
                {field.isFile && <span class="text-xs text-[var(--color-text-muted)] ml-1">(file)</span>}
              </span>
              {field.isFile ? (
                <input
                  type="file"
                  class="multipart-field flex-1 px-3 py-2 text-sm bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] rounded-md text-[var(--color-text-primary)] file:mr-3 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-[var(--color-accent-primary)]/10 file:text-[var(--color-accent-primary)] hover:file:bg-[var(--color-accent-primary)]/20 cursor-pointer"
                  data-field-name={field.name}
                  data-field-type="file"
                  accept=".csv,.xls,.xlsx,.json,.jsonl"
                />
              ) : (
                <input
                  type="text"
                  class="multipart-field flex-1 px-3 py-2 text-sm bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] rounded-md text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-primary)]/50"
                  placeholder={field.defaultValue}
                  value={field.defaultValue}
                  data-field-name={field.name}
                  data-field-type="text"
                />
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Response Section -->
    <div class="space-y-2">
      <div class="flex items-center justify-between">
        <label class="block text-sm font-medium text-[var(--color-text-primary)]">
          Response
        </label>
        <span class="response-status text-xs font-medium px-2 py-1 rounded hidden"></span>
      </div>
      <div class="response-container relative">
        <pre class="response-body w-full min-h-[100px] max-h-[400px] overflow-auto px-4 py-3 text-sm font-mono bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] rounded-md text-[var(--color-text-secondary)]">
          Click "Try It" to send a request
        </pre>
        <div class="response-loading hidden absolute inset-0 flex items-center justify-center bg-[var(--color-bg-primary)]/80 rounded-md">
          <svg class="animate-spin h-6 w-6 text-[var(--color-accent-primary)]" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ playgroundId, method, endpoint, baseUrl, contentType, hiddenFields }}>
  document.addEventListener('DOMContentLoaded', () => {
    const playground = document.querySelector(`[data-playground-id="${playgroundId}"]`);
    if (!playground) return;

    const tryBtn = playground.querySelector('.try-it-btn');
    const responseBody = playground.querySelector('.response-body');
    const responseStatus = playground.querySelector('.response-status');
    const responseLoading = playground.querySelector('.response-loading');

    tryBtn?.addEventListener('click', async () => {
      // Get authentication keys
      const apiKeyInput = playground.querySelector('.api-key-input');
      const secretKeyInput = playground.querySelector('.secret-key-input');
      const apiKey = apiKeyInput?.value || '';
      const secretKey = secretKeyInput?.value || '';

      // Build URL with path parameters
      let url = baseUrl + endpoint;
      const pathParams = playground.querySelectorAll('.path-param');
      pathParams.forEach(input => {
        const name = input.dataset.paramName;
        const value = input.value;
        if (name && value) {
          url = url.replace(`{${name}}`, encodeURIComponent(value));
        }
      });

      // Add query parameters
      const queryParams = playground.querySelectorAll('.query-param');
      const queryString = new URLSearchParams();
      queryParams.forEach(input => {
        const name = input.dataset.paramName;
        const value = input.value;
        if (name && value) {
          queryString.append(name, value);
        }
      });
      if (queryString.toString()) {
        url += '?' + queryString.toString();
      }

      // Build request body
      const isMultipart = contentType === 'multipart';
      let body = null;
      let formData = null;

      if (isMultipart) {
        formData = new FormData();
        const fields = playground.querySelectorAll('.multipart-field');
        fields.forEach(input => {
          const name = input.dataset.fieldName;
          const type = input.dataset.fieldType;
          if (!name) return;
          if (type === 'file') {
            if (input.files && input.files.length > 0) {
              formData.append(name, input.files[0]);
            }
          } else {
            if (input.value) {
              formData.append(name, input.value);
            }
          }
        });
        // Append hidden fields
        for (const [key, val] of Object.entries(hiddenFields)) {
          formData.append(key, val);
        }
      } else {
        const bodyTextarea = playground.querySelector('.request-body');
        if (bodyTextarea && bodyTextarea.value) {
          try {
            body = JSON.parse(bodyTextarea.value);
            // Merge hidden fields
            for (const [key, val] of Object.entries(hiddenFields)) {
              body[key] = val;
            }
          } catch (e) {
            responseBody.textContent = 'Error: Invalid JSON in request body';
            responseStatus.textContent = 'Error';
            responseStatus.className = 'response-status text-xs font-medium px-2 py-1 rounded bg-red-500/10 text-red-500';
            return;
          }
        }
      }

      // Show loading
      responseLoading?.classList.remove('hidden');
      responseBody.textContent = '';

      try {
        const headers = {};
        if (!isMultipart) {
          headers['Content-Type'] = 'application/json';
        }
        if (apiKey) {
          headers['X-Api-Key'] = apiKey;
        }
        if (secretKey) {
          headers['X-Secret-Key'] = secretKey;
        }

        const options = {
          method: method,
          headers: headers,
        };

        if (method === 'POST' || method === 'PUT' || method === 'PATCH') {
          if (isMultipart && formData) {
            options.body = formData;
          } else if (body) {
            options.body = JSON.stringify(body);
          }
        }

        const response = await fetch(url, options);
        const data = await response.json();

        responseBody.textContent = JSON.stringify(data, null, 2);

        if (response.ok) {
          responseStatus.textContent = `${response.status} ${response.statusText}`;
          responseStatus.className = 'response-status text-xs font-medium px-2 py-1 rounded bg-emerald-500/10 text-emerald-500';
        } else {
          responseStatus.textContent = `${response.status} ${response.statusText}`;
          responseStatus.className = 'response-status text-xs font-medium px-2 py-1 rounded bg-red-500/10 text-red-500';
        }
        responseStatus.classList.remove('hidden');
      } catch (error) {
        responseBody.textContent = `Error: ${error.message}\n\nNote: CORS restrictions may prevent API calls from the browser.\nUse the code examples below to make requests from your server.`;
        responseStatus.textContent = 'Error';
        responseStatus.className = 'response-status text-xs font-medium px-2 py-1 rounded bg-red-500/10 text-red-500';
        responseStatus.classList.remove('hidden');
      } finally {
        responseLoading?.classList.add('hidden');
      }
    });
  });
</script>
