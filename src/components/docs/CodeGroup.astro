---
/**
 * CodeGroup Component
 * Groups multiple code blocks with tabs
 * Works with Mintlify-style code blocks (```python Python)
 */
interface Props {
  titles?: string[];
}

const { titles = [] } = Astro.props;
const id = `code-group-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="my-6 rounded-xl border border-[var(--color-border-default)] overflow-hidden code-group-container" data-code-group={id}>
  <!-- Language tabs will be generated from code block titles if not provided -->
  {titles && titles.length > 0 && (
    <div class="code-tabs flex bg-[var(--color-bg-tertiary)] border-b border-[var(--color-border-default)] overflow-x-auto hide-scrollbar">
      {titles.map((title, index) => (
        <button
          type="button"
          class:list={[
            "px-4 py-2.5 text-sm font-medium transition-colors whitespace-nowrap",
            index === 0
              ? "bg-[var(--color-bg-secondary)] text-[var(--color-text-primary)]"
              : "text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)]"
          ]}
          data-code-tab={index}
        >
          {title}
        </button>
      ))}
    </div>
  )}

  <!-- Code panels -->
  <div class="code-panels relative [&>pre]:!rounded-none [&>pre]:!border-0 [&>pre]:!my-0 [&>div>pre]:!rounded-none [&>div>pre]:!border-0 [&>div>pre]:!my-0">
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll('[data-code-group]').forEach((group) => {
    let tabsContainer = group.querySelector('.code-tabs');
    const panels = group.querySelector('.code-panels');

    if (!panels) return;

    // Get all direct code blocks or divs containing code blocks
    const codeBlocks = Array.from(panels.children).filter(el => {
      return el.tagName === 'PRE' ||
             (el.tagName === 'DIV' && el.querySelector('pre')) ||
             el.classList.contains('astro-code');
    });

    if (codeBlocks.length === 0) return;

    // If no tabs provided, create them from code block languages
    if (!tabsContainer) {
      tabsContainer = document.createElement('div');
      tabsContainer.className = 'code-tabs flex bg-[var(--color-bg-tertiary)] border-b border-[var(--color-border-default)] overflow-x-auto hide-scrollbar';

      codeBlocks.forEach((block, index) => {
        // Try to extract language from class or data attribute
        let title = 'Code';
        const pre = block.tagName === 'PRE' ? block : block.querySelector('pre');
        if (pre) {
          const langMatch = pre.className?.match(/language-(\w+)/);
          if (langMatch) {
            title = langMatch[1].charAt(0).toUpperCase() + langMatch[1].slice(1);
          }
          // Check data-language
          const dataLang = pre.getAttribute('data-language');
          if (dataLang) {
            title = dataLang;
          }
        }

        const button = document.createElement('button');
        button.type = 'button';
        button.className = index === 0
          ? 'px-4 py-2.5 text-sm font-medium transition-colors whitespace-nowrap bg-[var(--color-bg-secondary)] text-[var(--color-text-primary)]'
          : 'px-4 py-2.5 text-sm font-medium transition-colors whitespace-nowrap text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)]';
        button.setAttribute('data-code-tab', String(index));
        button.textContent = title;
        tabsContainer?.appendChild(button);
      });

      panels.parentElement?.insertBefore(tabsContainer, panels);
    }

    // Initialize panels visibility
    codeBlocks.forEach((block, index) => {
      block.classList.toggle('hidden', index !== 0);
    });

    // Add click handlers
    const tabs = tabsContainer.querySelectorAll('[data-code-tab]');
    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t, i) => {
          if (i === index) {
            t.classList.add('bg-[var(--color-bg-secondary)]', 'text-[var(--color-text-primary)]');
            t.classList.remove('text-[var(--color-text-tertiary)]');
          } else {
            t.classList.remove('bg-[var(--color-bg-secondary)]', 'text-[var(--color-text-primary)]');
            t.classList.add('text-[var(--color-text-tertiary)]');
          }
        });

        codeBlocks.forEach((block, i) => {
          block.classList.toggle('hidden', i !== index);
        });
      });
    });
  });
</script>
