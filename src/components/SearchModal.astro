---
/**
 * Search Modal Component
 * Navigation-based search with keyboard support (arrow keys + enter)
 * Search data fetched on demand from /search-data.json (saves 34KB per page)
 */
---

<!-- Search Modal Overlay -->
<div id="search-modal" class="search-modal-overlay" style="display: none;">
  <div class="search-modal-backdrop"></div>
  <div class="search-modal-container">
    <div class="search-modal-content">
      <!-- Search Input Header -->
      <div class="search-header">
        <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder="Search..."
          autocomplete="off"
        />
        <kbd class="search-kbd">ESC</kbd>
      </div>

      <!-- Results Container -->
      <div id="search-results" class="search-results"></div>

      <!-- Ask AI Footer -->
      <div class="search-footer">
        <span class="search-footer-label">Ask AI assistant</span>
        <button type="button" id="ask-ai-from-search" class="search-ai-btn">
          <svg class="ai-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
          <span id="ai-query-text">Can you tell me about Future AGI?</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var pages = [];
  var dataLoaded = false;
  var debounceTimer = null;

  function ensureSearchData() {
    if (dataLoaded) return Promise.resolve();
    return fetch('/search-data.json')
      .then(function(r) { return r.json(); })
      .then(function(data) { pages = data; dataLoaded = true; })
      .catch(function() { pages = []; });
  }

  function escapeHtml(text) {
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function highlight(text, terms) {
    var escaped = escapeHtml(text);
    terms.forEach(function(t) {
      if (t.length > 1) {
        var re = new RegExp('(' + t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        escaped = escaped.replace(re, '<mark>$1</mark>');
      }
    });
    return escaped;
  }

  function setupSearch() {
    var modal = document.getElementById('search-modal');
    var input = document.getElementById('search-input');
    var results = document.getElementById('search-results');
    var backdrop = modal ? modal.querySelector('.search-modal-backdrop') : null;

    if (!modal || !input || !results) return;

    var activeIndex = -1;

    function getItems() {
      return results.querySelectorAll('.result-item');
    }

    function setActive(index) {
      var items = getItems();
      if (items.length === 0) return;
      items.forEach(function(el) { el.classList.remove('result-active'); });
      if (index < 0) index = items.length - 1;
      if (index >= items.length) index = 0;
      activeIndex = index;
      var active = items[activeIndex];
      active.classList.add('result-active');
      active.scrollIntoView({ block: 'nearest' });
    }

    window.openSearchModal = function() {
      var m = document.getElementById('search-modal');
      var i = document.getElementById('search-input');
      if (m) {
        m.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        ensureSearchData(); // Fetch search data on first open
        setTimeout(function() { if (i) i.focus(); }, 50);
      }
    };

    window.closeSearchModal = function() {
      var m = document.getElementById('search-modal');
      var i = document.getElementById('search-input');
      var r = document.getElementById('search-results');
      var q = document.getElementById('ai-query-text');
      if (m) {
        m.style.display = 'none';
        document.body.style.overflow = '';
      }
      if (i) i.value = '';
      if (r) r.innerHTML = '';
      if (q) q.textContent = 'Can you tell me about Future AGI?';
      activeIndex = -1;
    };

    if (backdrop && !backdrop._listener) {
      backdrop._listener = true;
      backdrop.addEventListener('click', window.closeSearchModal);
    }

    if (input && !input._listener) {
      input._listener = true;

      input.addEventListener('input', function(e) {
        clearTimeout(debounceTimer);
        activeIndex = -1;
        debounceTimer = setTimeout(function() { doSearch(e.target.value); }, 100);
      });

      input.addEventListener('keydown', function(e) {
        var items = getItems();
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          setActive(activeIndex + 1);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          setActive(activeIndex - 1);
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIndex >= 0 && activeIndex < items.length) {
            window.closeSearchModal();
            window.location.href = items[activeIndex].getAttribute('href');
          }
        } else if (e.key === 'Escape') {
          window.closeSearchModal();
        }
      });
    }

    function doSearch(query) {
      var r = document.getElementById('search-results');
      var q = document.getElementById('ai-query-text');

      if (!query || !query.trim()) {
        if (r) r.innerHTML = '';
        if (q) q.textContent = 'Can you tell me about Future AGI?';
        return;
      }

      if (q) q.textContent = 'Can you tell me about ' + query + '?';

      var terms = query.trim().toLowerCase().split(/\s+/).filter(function(t) { return t; });
      var matched = pages.filter(function(p) {
        var haystack = (p.title + ' ' + p.group + ' ' + p.tab + ' ' + p.href).toLowerCase();
        return terms.every(function(t) { return haystack.indexOf(t) !== -1; });
      }).slice(0, 10);

      if (!r) return;

      if (matched.length === 0) {
        r.innerHTML = '<div class="no-results">No results found</div>';
        return;
      }

      r.innerHTML = matched.map(function(item) {
        return '<a href="' + item.href + '" class="result-item">' +
          '<span class="result-breadcrumb">' + escapeHtml(item.tab) + ' &rsaquo; ' + escapeHtml(item.group) + '</span>' +
          '<span class="result-title">' + highlight(item.title, terms) + '</span>' +
        '</a>';
      }).join('');
      activeIndex = -1;
    }

    var aiBtn = document.getElementById('ask-ai-from-search');
    if (aiBtn && !aiBtn._listener) {
      aiBtn._listener = true;
      aiBtn.addEventListener('click', function() {
        window.closeSearchModal();
        if (typeof window.openAiChat === 'function') {
          window.openAiChat();
        }
      });
    }

    if (!window._escListener) {
      window._escListener = true;
      document.addEventListener('keydown', function(e) {
        var m = document.getElementById('search-modal');
        if (e.key === 'Escape' && m && m.style.display === 'flex') {
          window.closeSearchModal();
        }
      });
    }
  }

  setupSearch();
  document.addEventListener('astro:page-load', setupSearch);
})();
</script>

<style is:global>
  .search-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
  }

  .search-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .search-modal-container {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 1rem;
  }

  .search-modal-content {
    background: #18181b;
    border: 1px solid #27272a;
    border-radius: 12px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
    overflow: hidden;
  }

  /* Header */
  .search-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border-bottom: 1px solid #27272a;
  }

  .search-icon {
    width: 20px;
    height: 20px;
    color: #71717a;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-size: 16px;
    color: #fafafa;
  }

  .search-input::placeholder {
    color: #71717a;
  }

  .search-kbd {
    padding: 4px 8px;
    font-size: 12px;
    font-family: ui-monospace, monospace;
    background: #27272a;
    border-radius: 6px;
    color: #a1a1aa;
  }

  /* Results */
  .search-results {
    max-height: 400px;
    overflow-y: auto;
  }

  .no-results {
    padding: 48px 16px;
    text-align: center;
    color: #71717a;
    font-size: 14px;
  }

  /* Each result item */
  .result-item {
    display: block;
    padding: 10px 16px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid #27272a;
  }

  .result-item:last-child {
    border-bottom: none;
  }

  .result-item:hover,
  .result-item.result-active {
    background: #27272a;
  }

  /* Breadcrumb */
  .result-breadcrumb {
    display: block;
    font-size: 11px;
    color: #71717a;
    line-height: 1.4;
    margin-bottom: 2px;
  }

  /* Title */
  .result-title {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #fafafa;
    line-height: 1.5;
  }

  .result-title mark {
    background: none;
    color: #8b5cf6;
    font-weight: 700;
  }

  /* Footer */
  .search-footer {
    padding: 12px 16px;
    border-top: 1px solid #27272a;
  }

  .search-footer-label {
    font-size: 11px;
    color: #71717a;
    margin-bottom: 8px;
    display: block;
  }

  .search-ai-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 10px 12px;
    background: transparent;
    border: none;
    border-radius: 8px;
    color: #fafafa;
    font-size: 14px;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
  }

  .search-ai-btn:hover {
    background: #27272a;
  }

  .ai-icon {
    width: 16px;
    height: 16px;
    color: #8b5cf6;
    flex-shrink: 0;
  }

  /* Scrollbar */
  .search-results::-webkit-scrollbar {
    width: 8px;
  }

  .search-results::-webkit-scrollbar-track {
    background: transparent;
  }

  .search-results::-webkit-scrollbar-thumb {
    background: #3f3f46;
    border-radius: 4px;
  }
</style>
