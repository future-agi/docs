---
/**
 * Search Modal Component
 * Uses Pagefind for full-text search with custom modal UI
 * Design based on Braintrust's search modal
 */
---

<!-- Search Modal Overlay -->
<div id="search-modal" class="search-modal-overlay" style="display: none;">
  <div class="search-modal-backdrop"></div>
  <div class="search-modal-container">
    <div class="search-modal-content">
      <!-- Search Input Header -->
      <div class="search-header">
        <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder="Search..."
          autocomplete="off"
        />
        <kbd class="search-kbd">ESC</kbd>
      </div>

      <!-- Pagefind Results Container -->
      <div id="search-results" class="search-results"></div>

      <!-- Ask AI Footer -->
      <div class="search-footer">
        <span class="search-footer-label">Ask AI assistant</span>
        <button type="button" id="ask-ai-from-search" class="search-ai-btn">
          <svg class="ai-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
          <span id="ai-query-text">Can you tell me about Future AGI?</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  let pagefind = null;
  let debounceTimer = null;

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      pagefind = await import('/pagefind/pagefind.js');
      return pagefind;
    } catch (e) {
      console.log('Pagefind not available');
      return null;
    }
  }

  function setupSearch() {
    const modal = document.getElementById('search-modal');
    const input = document.getElementById('search-input');
    const backdrop = modal?.querySelector('.search-modal-backdrop');

    if (!modal || !input) return;

    window.openSearchModal = function() {
      const m = document.getElementById('search-modal');
      const i = document.getElementById('search-input');
      if (m) {
        m.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        loadPagefind();
        setTimeout(() => i?.focus(), 50);
      }
    };

    window.closeSearchModal = function() {
      const m = document.getElementById('search-modal');
      const i = document.getElementById('search-input');
      const r = document.getElementById('search-results');
      const q = document.getElementById('ai-query-text');
      if (m) {
        m.style.display = 'none';
        document.body.style.overflow = '';
      }
      if (i) i.value = '';
      if (r) r.innerHTML = '';
      if (q) q.textContent = 'Can you tell me about Future AGI?';
    };

    if (backdrop && !backdrop._listener) {
      backdrop._listener = true;
      backdrop.addEventListener('click', window.closeSearchModal);
    }

    function highlightTerm(text, term) {
      if (!term || !text) return escapeHtml(text || '');
      const escaped = escapeHtml(text);
      const words = term.trim().split(/\s+/);
      let result = escaped;
      words.forEach(word => {
        if (word.length > 1) {
          const regex = new RegExp('(' + word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
          result = result.replace(regex, '<mark>$1</mark>');
        }
      });
      return result;
    }

    // Determine page category from URL
    function getPageCategory(url) {
      if (url.includes('/docs/api/')) return 'api';
      if (url.includes('/docs/cookbook/')) return 'cookbook';
      if (url.includes('/docs/integrations/')) return 'integration';
      if (url.includes('/docs/evaluation/')) return 'evaluation';
      if (url.includes('/docs/sdk/')) return 'sdk';
      if (url.includes('/docs/tracing/')) return 'tracing';
      if (url.includes('/docs/observe/')) return 'observe';
      if (url.includes('/docs/dataset/')) return 'dataset';
      if (url.includes('/docs/protect/')) return 'protect';
      if (url.includes('/docs/prompt/')) return 'prompt';
      if (url.includes('/changelog')) return 'changelog';
      return 'docs';
    }

    // Get HTTP method from page content for API pages
    function detectHttpMethod(title, url) {
      const lowerTitle = title.toLowerCase();
      const lowerUrl = url.toLowerCase();

      // Check for common patterns
      if (lowerTitle.includes('delete') || lowerUrl.includes('delete')) return 'DELETE';
      if (lowerTitle.includes('create') || lowerTitle.includes('add') || lowerUrl.includes('create') || lowerUrl.includes('add')) return 'POST';
      if (lowerTitle.includes('update') || lowerTitle.includes('edit') || lowerUrl.includes('update') || lowerUrl.includes('edit')) return 'PUT';
      if (lowerTitle.includes('list') || lowerTitle.includes('get') || lowerTitle.includes('retrieve') || lowerUrl.includes('list') || lowerUrl.includes('get')) return 'GET';
      if (lowerTitle.includes('execute') || lowerTitle.includes('apply')) return 'POST';

      return 'GET'; // Default for API
    }

    // Get category icon SVG
    function getCategoryIcon(category) {
      const icons = {
        api: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M9 9h6v6H9z"/></svg>',
        cookbook: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>',
        integration: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v6m0 8v6m-6-6H2m20 0h-4M7.8 7.8L4 4m16 16l-3.8-3.8M7.8 16.2L4 20M20 4l-3.8 3.8"/></svg>',
        evaluation: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22,4 12,14.01 9,11.01"/></svg>',
        sdk: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16,18 22,12 16,6"/><polyline points="8,6 2,12 8,18"/></svg>',
        tracing: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M18 9l-5 5-4-4-3 3"/></svg>',
        observe: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>',
        dataset: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>',
        protect: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
        prompt: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
        changelog: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>',
        docs: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>'
      };
      return icons[category] || icons.docs;
    }

    // Extract clean readable text - aggressively remove code
    function extractCleanText(excerpt) {
      if (!excerpt) return '';

      // Remove all HTML tags
      let text = excerpt.replace(/<[^>]+>/g, ' ');

      // Remove common code patterns
      text = text.replace(/[{}\[\]();=]/g, ' ');
      text = text.replace(/\b(curl|wget|npm|pip|import|from|def|function|const|let|var|class|return|if|else|for|while)\b/gi, ' ');
      text = text.replace(/https?:\/\/[^\s]+/g, ' ');
      text = text.replace(/[a-zA-Z_][a-zA-Z0-9_]*\s*[=:]\s*/g, ' ');
      text = text.replace(/"[^"]*"/g, ' ');
      text = text.replace(/'[^']*'/g, ' ');
      text = text.replace(/\d{2,}/g, ' ');

      // Clean whitespace
      text = text.replace(/\s+/g, ' ').trim();

      // Only return if we have meaningful text
      if (text.length < 20) return '';
      if (text.length > 80) text = text.substring(0, 80) + '...';

      return text;
    }

    async function doSearch(query) {
      const r = document.getElementById('search-results');
      const q = document.getElementById('ai-query-text');

      if (!query.trim()) {
        if (r) r.innerHTML = '';
        if (q) q.textContent = 'Can you tell me about Future AGI?';
        return;
      }

      if (q) q.textContent = `Can you tell me about ${query}?`;

      const pf = await loadPagefind();
      if (!pf) {
        if (r) r.innerHTML = '<div class="no-results">Search is loading...</div>';
        return;
      }

      const search = await pf.search(query);
      const data = await Promise.all(
        search.results.slice(0, 8).map(result => result.data())
      );

      if (!r) return;

      if (data.length === 0) {
        r.innerHTML = '<div class="no-results">No results found</div>';
        return;
      }

      r.innerHTML = data.map(item => {
        const url = item.url || '#';
        const title = item.meta?.title || 'Untitled';

        // Build breadcrumb from URL path
        const urlPath = url.replace(/^\//, '').replace(/\/$/, '').replace('/index.html', '');
        const parts = urlPath.split('/').filter(p => p);
        const breadcrumb = parts.map(p =>
          p.charAt(0).toUpperCase() + p.slice(1).replace(/-/g, ' ')
        ).join(' > ');

        // Determine category and build prefix
        const category = getPageCategory(url);
        const isApi = category === 'api';
        const httpMethod = isApi ? detectHttpMethod(title, url) : null;

        // Get description - prefer meta description, fallback to cleaned excerpt
        let desc = '';
        if (item.meta?.description) {
          desc = item.meta.description;
          if (desc.length > 100) desc = desc.substring(0, 100) + '...';
        } else {
          desc = extractCleanText(item.excerpt || '');
        }

        // Build the prefix: either HTTP method badge for API or category icon
        let prefixHtml;
        if (isApi && httpMethod) {
          prefixHtml = `<span class="result-method method-${httpMethod.toLowerCase()}">${httpMethod}</span>`;
        } else {
          prefixHtml = `<span class="result-category-icon category-${category}">${getCategoryIcon(category)}</span>`;
        }

        return `
          <a href="${url}" class="result-item" onclick="closeSearchModal()">
            <span class="result-breadcrumb">${escapeHtml(breadcrumb)}</span>
            <div class="result-title-row">
              ${prefixHtml}
              <span class="result-title">${highlightTerm(title, query)}</span>
            </div>
            ${desc ? `<span class="result-desc">${highlightTerm(desc, query)}</span>` : ''}
          </a>
        `;
      }).join('');
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    if (input && !input._listener) {
      input._listener = true;
      input.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => doSearch(e.target.value), 150);
      });
    }

    const aiBtn = document.getElementById('ask-ai-from-search');
    if (aiBtn && !aiBtn._listener) {
      aiBtn._listener = true;
      aiBtn.addEventListener('click', () => {
        window.closeSearchModal();
        // Use the global openAiChat function from Header
        if (typeof window.openAiChat === 'function') {
          window.openAiChat();
        }
      });
    }

    if (!window._escListener) {
      window._escListener = true;
      document.addEventListener('keydown', (e) => {
        const m = document.getElementById('search-modal');
        if (e.key === 'Escape' && m?.style.display === 'flex') {
          window.closeSearchModal();
        }
      });
    }
  }

  setupSearch();
  document.addEventListener('astro:page-load', setupSearch);
})();
</script>

<style is:global>
  .search-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
  }

  .search-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .search-modal-container {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 1rem;
  }

  .search-modal-content {
    background: #18181b;
    border: 1px solid #27272a;
    border-radius: 12px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
    overflow: hidden;
  }

  :root:not(.dark) .search-modal-content {
    background: #fff;
    border-color: #e4e4e7;
  }

  /* Header */
  .search-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border-bottom: 1px solid #27272a;
  }

  :root:not(.dark) .search-header {
    border-color: #e4e4e7;
  }

  .search-icon {
    width: 20px;
    height: 20px;
    color: #71717a;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-size: 16px;
    color: #fafafa;
  }

  :root:not(.dark) .search-input {
    color: #18181b;
  }

  .search-input::placeholder {
    color: #71717a;
  }

  .search-kbd {
    padding: 4px 8px;
    font-size: 12px;
    font-family: ui-monospace, monospace;
    background: #27272a;
    border-radius: 6px;
    color: #a1a1aa;
  }

  :root:not(.dark) .search-kbd {
    background: #f4f4f5;
    color: #71717a;
  }

  /* Results */
  .search-results {
    max-height: 400px;
    overflow-y: auto;
  }

  .no-results {
    padding: 48px 16px;
    text-align: center;
    color: #71717a;
    font-size: 14px;
  }

  /* Each result item */
  .result-item {
    display: block;
    padding: 12px 16px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid #27272a;
  }

  .result-item:last-child {
    border-bottom: none;
  }

  :root:not(.dark) .result-item {
    border-color: #e4e4e7;
  }

  .result-item:hover {
    background: #27272a;
  }

  :root:not(.dark) .result-item:hover {
    background: #f4f4f5;
  }

  /* Breadcrumb */
  .result-breadcrumb {
    display: block;
    font-size: 11px;
    color: #71717a;
    line-height: 1.4;
    margin-bottom: 4px;
  }

  /* Title row with icon/badge */
  .result-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  /* HTTP Method badges for API pages */
  .result-method {
    font-size: 10px;
    font-weight: 600;
    font-family: ui-monospace, monospace;
    padding: 2px 6px;
    border-radius: 4px;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .method-get {
    background: rgba(59, 130, 246, 0.15);
    color: #3b82f6;
  }

  .method-post {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
  }

  .method-put {
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
  }

  .method-delete {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }

  .method-patch {
    background: rgba(234, 179, 8, 0.15);
    color: #eab308;
  }

  /* Category icons */
  .result-category-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .result-category-icon svg {
    width: 14px;
    height: 14px;
  }

  /* Category colors */
  .category-cookbook { color: #a855f7; }
  .category-integration { color: #06b6d4; }
  .category-evaluation { color: #22c55e; }
  .category-sdk { color: #3b82f6; }
  .category-tracing { color: #f59e0b; }
  .category-observe { color: #ec4899; }
  .category-dataset { color: #8b5cf6; }
  .category-protect { color: #14b8a6; }
  .category-prompt { color: #f97316; }
  .category-changelog { color: #6366f1; }
  .category-docs { color: #71717a; }
  .category-api { color: #3b82f6; }

  /* Title */
  .result-title {
    font-size: 14px;
    font-weight: 600;
    color: #fafafa;
    line-height: 1.5;
  }

  :root:not(.dark) .result-title {
    color: #18181b;
  }

  .result-title mark {
    background: none;
    color: #3b82f6;
    font-weight: 600;
  }

  /* Description */
  .result-desc {
    display: block;
    font-size: 13px;
    color: #a1a1aa;
    line-height: 1.5;
    margin-left: 24px;
    margin-top: 2px;
  }

  :root:not(.dark) .result-desc {
    color: #71717a;
  }

  .result-desc mark {
    background: rgba(59, 130, 246, 0.15);
    color: #3b82f6;
    padding: 1px 2px;
    border-radius: 2px;
  }

  /* Footer */
  .search-footer {
    padding: 12px 16px;
    border-top: 1px solid #27272a;
  }

  :root:not(.dark) .search-footer {
    border-color: #e4e4e7;
  }

  .search-footer-label {
    font-size: 11px;
    color: #71717a;
    margin-bottom: 8px;
    display: block;
  }

  .search-ai-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 10px 12px;
    background: transparent;
    border: none;
    border-radius: 8px;
    color: #fafafa;
    font-size: 14px;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
  }

  :root:not(.dark) .search-ai-btn {
    color: #18181b;
  }

  .search-ai-btn:hover {
    background: #27272a;
  }

  :root:not(.dark) .search-ai-btn:hover {
    background: #f4f4f5;
  }

  .ai-icon {
    width: 16px;
    height: 16px;
    color: #3b82f6;
    flex-shrink: 0;
  }

  /* Scrollbar */
  .search-results::-webkit-scrollbar {
    width: 8px;
  }

  .search-results::-webkit-scrollbar-track {
    background: transparent;
  }

  .search-results::-webkit-scrollbar-thumb {
    background: #3f3f46;
    border-radius: 4px;
  }

  :root:not(.dark) .search-results::-webkit-scrollbar-thumb {
    background: #d4d4d8;
  }
</style>
