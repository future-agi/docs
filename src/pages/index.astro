---
/**
 * Documentation Homepage
 * Search-first design with space/planet background
 * Brand: Deep space, starship engineering, blueprint aesthetic
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const codeExample = `<span class="syntax-keyword">from</span> <span class="syntax-class">fi</span>.<span class="syntax-class">evals</span> <span class="syntax-keyword">import</span> evaluate
<span class="syntax-keyword">from</span> <span class="syntax-class">fi</span>.<span class="syntax-class">evals</span>.<span class="syntax-class">templates</span> <span class="syntax-keyword">import</span> Relevance

<span class="syntax-comment"># Evaluate any LLM output in one line</span>
result = <span class="syntax-function">evaluate</span>(
    <span class="syntax-variable">eval_templates</span>=[<span class="syntax-class">Relevance</span>()],
    <span class="syntax-variable">inputs</span>=[{<span class="syntax-string">"response"</span>: <span class="syntax-string">"Paris is the capital."</span>}]
)`;

const popularSearches = [
  { label: "RAG evaluation", href: "/docs/evaluation/rag" },
  { label: "Tracing setup", href: "/docs/tracing" },
  { label: "Guardrails", href: "/docs/protect" },
  { label: "LangChain", href: "/docs/integrations/langchain" },
  { label: "Python SDK", href: "/docs/sdk" },
];

const products = [
  {
    title: "Simulate",
    description: "Test with synthetic users and edge cases before production",
    href: "/docs/simulate",
    icon: "play",
    color: "purple"
  },
  {
    title: "Evaluate",
    description: "70+ metrics for quality, safety, hallucination detection",
    href: "/docs/evaluate",
    icon: "check",
    color: "emerald"
  },
  {
    title: "Guard",
    description: "Real-time guardrails, PII detection, prompt injection blocking",
    href: "/docs/protect",
    icon: "shield",
    color: "red"
  },
  {
    title: "Monitor",
    description: "Production tracing, cost tracking, latency monitoring",
    href: "/docs/tracing",
    icon: "eye",
    color: "blue"
  }
];
---

<BaseLayout title="Future AGI Documentation" description="Complete documentation for Future AGI - evaluate, observe, and optimize your AI applications.">
  <Header />

  <main class="pt-14">
    <!-- Hero Section with Space Background -->
    <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
      <!-- Space Background -->
      <div class="absolute inset-0 bg-[var(--color-bg-primary)]">
        <!-- Stars -->
        <div class="stars"></div>
        <div class="stars stars-2"></div>
        <div class="stars stars-3"></div>

        <!-- Planet 1 - Large, bottom right -->
        <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full bg-gradient-to-br from-[#1a1a1a] via-[#252525] to-[#0a0a0a] opacity-60 blur-sm"></div>
        <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full border border-[#333] opacity-40"></div>

        <!-- Planet 2 - Small, top left -->
        <div class="absolute -top-16 -left-16 w-48 h-48 rounded-full bg-gradient-to-br from-[#1f1f1f] to-[#0d0d0d] opacity-50"></div>
        <div class="absolute -top-16 -left-16 w-48 h-48 rounded-full border border-[#2a2a2a] opacity-30"></div>

        <!-- Moon - Small, floating -->
        <div class="absolute top-1/4 right-1/4 w-8 h-8 rounded-full bg-gradient-to-br from-[#3a3a3a] to-[#1a1a1a] opacity-40"></div>

        <!-- Nebula glow -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-[radial-gradient(ellipse_at_center,rgba(255,255,255,0.03)_0%,transparent_70%)]"></div>

        <!-- Blueprint grid overlay -->
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;"></div>
      </div>

      <!-- Hero Content -->
      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-bg-secondary)] border border-[var(--color-border-default)] text-xs text-[var(--color-text-tertiary)] mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
          <span>70+ evaluation metrics available</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-[var(--color-text-primary)] mb-4 leading-[1.1]">
          Build AI agents that<br/>
          <span class="text-[var(--color-text-tertiary)]">don't hallucinate</span>
        </h1>

        <p class="text-lg sm:text-xl text-[var(--color-text-secondary)] mb-10 max-w-2xl mx-auto">
          Simulate, evaluate, guard, and monitor your AI applications. One platform for reliable AI.
        </p>

        <!-- Search Bar -->
        <div class="max-w-2xl mx-auto mb-6">
          <button
            type="button"
            id="hero-search-button"
            class="w-full flex items-center gap-3 px-5 py-4 bg-[var(--color-bg-secondary)] border border-[var(--color-border-default)] rounded-xl text-left hover:border-[var(--color-border-accent)] hover:bg-[var(--color-bg-tertiary)] transition-all group"
          >
            <svg class="w-5 h-5 text-[var(--color-text-muted)] group-hover:text-[var(--color-text-tertiary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="flex-1 text-[var(--color-text-muted)]">Search documentation...</span>
            <kbd class="hidden sm:inline-flex items-center gap-1 px-2 py-1 text-xs font-medium bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)] rounded border border-[var(--color-border-subtle)]">
              <span>⌘</span><span>K</span>
            </kbd>
          </button>
        </div>

        <!-- Popular Searches -->
        <div class="flex flex-wrap justify-center gap-2 mb-12">
          <span class="text-xs text-[var(--color-text-muted)]">Popular:</span>
          {popularSearches.map((item) => (
            <a
              href={item.href}
              class="text-xs text-[var(--color-text-tertiary)] hover:text-[var(--color-text-primary)] transition-colors"
            >
              {item.label}
            </a>
          ))}
        </div>

        <!-- Quick Start Buttons -->
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/docs/quickstart" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-full bg-[var(--color-text-primary)] text-[var(--color-bg-primary)] hover:shadow-[0_0_30px_rgba(255,255,255,0.15)] transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Get started
          </a>
          <a href="https://github.com/future-agi" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-full border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- Product Flow Section -->
    <section class="py-20 border-t border-[var(--color-border-subtle)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-12">
          <p class="text-xs font-medium tracking-widest text-[var(--color-text-muted)] uppercase mb-3">The Journey</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text-primary)]">
            From prototype to production
          </h2>
        </div>

        <!-- Flow Cards -->
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
          {products.map((product, index) => (
            <a
              href={product.href}
              class="group relative p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-border-accent)] transition-all"
            >
              <!-- Step number -->
              <div class="absolute top-4 right-4 text-xs font-mono text-[var(--color-text-muted)]">
                0{index + 1}
              </div>

              <!-- Icon -->
              <div class={`w-10 h-10 rounded-lg bg-${product.color}-500/10 flex items-center justify-center mb-4`}>
                {product.icon === "play" && (
                  <svg class={`w-5 h-5 text-${product.color}-500`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
                {product.icon === "check" && (
                  <svg class={`w-5 h-5 text-${product.color}-500`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
                {product.icon === "shield" && (
                  <svg class={`w-5 h-5 text-${product.color}-500`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                )}
                {product.icon === "eye" && (
                  <svg class={`w-5 h-5 text-${product.color}-500`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                )}
              </div>

              <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-text-primary)]">
                {product.title}
              </h3>
              <p class="text-sm text-[var(--color-text-tertiary)]">
                {product.description}
              </p>

              <!-- Arrow -->
              <div class="absolute bottom-6 right-6 opacity-0 group-hover:opacity-100 transition-opacity">
                <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Code Example Section -->
    <section class="py-20 bg-[var(--color-bg-secondary)]/30 border-y border-[var(--color-border-subtle)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-xs font-medium tracking-widest text-[var(--color-text-muted)] uppercase mb-3">Quick Start</p>
            <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text-primary)] mb-4">
              Evaluate in 3 lines of code
            </h2>
            <p class="text-[var(--color-text-secondary)] mb-8">
              Install the SDK and start evaluating LLM outputs immediately. No configuration required.
            </p>

            <!-- Install command -->
            <div class="mb-8">
              <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] font-mono text-sm">
                <span class="text-[var(--color-text-muted)]">$</span>
                <span class="text-[var(--color-text-primary)]">pip install futureagi</span>
                <button class="ml-auto p-1.5 hover:bg-[var(--color-bg-hover)] rounded transition-colors" title="Copy">
                  <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </button>
              </div>
            </div>

            <ul class="space-y-3 mb-8">
              <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>70+ built-in evaluation templates</span>
              </li>
              <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>One-line tracing with decorators</span>
              </li>
              <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>LangChain, LlamaIndex, OpenAI integrations</span>
              </li>
            </ul>

            <a href="/docs/quickstart" class="inline-flex items-center gap-2 text-[var(--color-text-primary)] font-medium hover:underline underline-offset-4">
              Read the quickstart guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>

          <!-- Code block -->
          <div class="relative">
            <div class="rounded-xl bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] overflow-hidden">
              <div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--color-border-subtle)] bg-[var(--color-bg-tertiary)]">
                <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
                <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
                <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
                <span class="ml-2 text-xs text-[var(--color-text-muted)] font-mono">evaluate.py</span>
              </div>
              <pre class="p-5 text-sm overflow-x-auto"><code class="text-[var(--color-text-secondary)]" set:html={codeExample} /></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Resources Grid -->
    <section class="py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">
            Explore the docs
          </h2>
          <a href="/docs" class="text-sm text-[var(--color-text-tertiary)] hover:text-[var(--color-text-primary)] transition-colors">
            View all →
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <a href="/docs/evaluation/builtin" class="group p-5 rounded-xl border border-[var(--color-border-subtle)] hover:border-[var(--color-border-accent)] bg-[var(--color-bg-secondary)]/50 transition-all">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </div>
              <h3 class="font-medium text-[var(--color-text-primary)]">All Metrics</h3>
            </div>
            <p class="text-sm text-[var(--color-text-tertiary)]">Browse 70+ built-in evaluation templates for any use case</p>
          </a>

          <a href="/docs/api" class="group p-5 rounded-xl border border-[var(--color-border-subtle)] hover:border-[var(--color-border-accent)] bg-[var(--color-bg-secondary)]/50 transition-all">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="font-medium text-[var(--color-text-primary)]">API Reference</h3>
            </div>
            <p class="text-sm text-[var(--color-text-tertiary)]">Complete REST API documentation with interactive playground</p>
          </a>

          <a href="/docs/sdk" class="group p-5 rounded-xl border border-[var(--color-border-subtle)] hover:border-[var(--color-border-accent)] bg-[var(--color-bg-secondary)]/50 transition-all">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77l-.69.05-.59.14-.5.22-.41.27-.33.32-.27.35-.2.36-.15.37-.1.35-.07.32-.04.27-.02.21v3.06H3.17l-.21-.03-.28-.07-.32-.12-.35-.18-.36-.26-.36-.36-.35-.46-.32-.59-.28-.73-.21-.88-.14-1.05-.05-1.23.06-1.22.16-1.04.24-.87.32-.71.36-.57.4-.44.42-.33.42-.24.4-.16.36-.1.32-.05.24-.01h.16l.06.01h8.16v-.83H6.18l-.01-2.75-.02-.37.05-.34.11-.31.17-.28.25-.26.31-.23.38-.2.44-.18.51-.15.58-.12.64-.1.71-.06.77-.04.84-.02 1.27.05z"/>
                </svg>
              </div>
              <h3 class="font-medium text-[var(--color-text-primary)]">Python SDK</h3>
            </div>
            <p class="text-sm text-[var(--color-text-tertiary)]">Install and configure the SDK for your Python project</p>
          </a>

          <a href="/docs/cookbook" class="group p-5 rounded-xl border border-[var(--color-border-subtle)] hover:border-[var(--color-border-accent)] bg-[var(--color-bg-secondary)]/50 transition-all">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
              <h3 class="font-medium text-[var(--color-text-primary)]">Cookbooks</h3>
            </div>
            <p class="text-sm text-[var(--color-text-tertiary)]">End-to-end tutorials and example projects</p>
          </a>

          <a href="/docs/integrations" class="group p-5 rounded-xl border border-[var(--color-border-subtle)] hover:border-[var(--color-border-accent)] bg-[var(--color-bg-secondary)]/50 transition-all">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 rounded-lg bg-cyan-500/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
