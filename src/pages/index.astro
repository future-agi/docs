---
/**
 * Documentation Homepage
 * Inspired by Stripe, Sentry, and Cloudflare docs:
 * - Prominent search bar in hero
 * - Quick action links for common tasks
 * - Product category cards
 * - Featured/popular resources
 * - Code example with playground
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const codeExample = `<span class="syntax-keyword">from</span> <span class="syntax-class">fi</span>.<span class="syntax-class">evals</span> <span class="syntax-keyword">import</span> evaluate, Evaluator
<span class="syntax-keyword">from</span> <span class="syntax-class">fi</span>.<span class="syntax-class">evals</span>.<span class="syntax-class">templates</span> <span class="syntax-keyword">import</span> Relevance

<span class="syntax-comment"># Evaluate any LLM output in one line</span>
result = <span class="syntax-function">evaluate</span>(
    <span class="syntax-variable">eval_templates</span>=[<span class="syntax-class">Relevance</span>()],
    <span class="syntax-variable">inputs</span>=[{<span class="syntax-string">"response"</span>: <span class="syntax-string">"Paris is the capital of France."</span>}]
)

<span class="syntax-keyword">print</span>(result)  <span class="syntax-comment"># Score: 0.95</span>`;
---

<BaseLayout title="Future AGI Documentation" description="Complete documentation for Future AGI - evaluate, observe, and optimize your AI applications with 70+ metrics, real-time tracing, and automated testing.">
  <Header />

  <main class="pt-14">
    <!-- Hero Section - Stripe/Cloudflare inspired -->
    <section class="relative overflow-hidden">
      <!-- Background gradient -->
      <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-accent-primary)]/[0.03] to-transparent"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,var(--color-accent-primary)/5,transparent_50%)]"></div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8 lg:pt-16 lg:pb-12">
        <!-- Main heading -->
        <div class="text-center max-w-3xl mx-auto mb-8">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-[var(--color-text-primary)] mb-4">
            Future AGI Documentation
          </h1>
          <p class="text-lg sm:text-xl text-[var(--color-text-secondary)] leading-relaxed">
            Build reliable AI applications with comprehensive evaluation, observability, and optimization tools.
          </p>
        </div>

        <!-- Quick Actions - Cloudflare inspired -->
        <div class="flex flex-wrap justify-center gap-3 mb-12">
          <a href="/docs/quickstart" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-[var(--color-accent-primary)] text-white hover:bg-[var(--color-accent-primary)]/90 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Get started
          </a>
          <a href="/docs/api" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] hover:border-[var(--color-border-default)] transition-colors">
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            API Reference
          </a>
          <a href="/docs/sdk" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] hover:border-[var(--color-border-default)] transition-colors">
            <svg class="w-4 h-4 text-[#3776AB]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77l-.69.05-.59.14-.5.22-.41.27-.33.32-.27.35-.2.36-.15.37-.1.35-.07.32-.04.27-.02.21v3.06H3.17l-.21-.03-.28-.07-.32-.12-.35-.18-.36-.26-.36-.36-.35-.46-.32-.59-.28-.73-.21-.88-.14-1.05-.05-1.23.06-1.22.16-1.04.24-.87.32-.71.36-.57.4-.44.42-.33.42-.24.4-.16.36-.1.32-.05.24-.01h.16l.06.01h8.16v-.83H6.18l-.01-2.75-.02-.37.05-.34.11-.31.17-.28.25-.26.31-.23.38-.2.44-.18.51-.15.58-.12.64-.1.71-.06.77-.04.84-.02 1.27.05zm-6.3 1.98l-.23.33-.08.41.08.41.23.34.33.22.41.09.41-.09.33-.22.23-.34.08-.41-.08-.41-.23-.33-.33-.22-.41-.09-.41.09zm13.09 3.95l.28.06.32.12.35.18.36.27.36.35.35.47.32.59.28.73.21.88.14 1.04.05 1.23-.06 1.23-.16 1.04-.24.86-.32.71-.36.57-.4.45-.42.33-.42.24-.4.16-.36.09-.32.05-.24.02-.16-.01h-8.22v.82h5.84l.01 2.76.02.36-.05.34-.11.31-.17.29-.25.25-.31.24-.38.2-.44.17-.51.15-.58.13-.64.09-.71.07-.77.04-.84.01-1.27-.04-1.07-.14-.9-.2-.73-.25-.59-.3-.45-.33-.34-.34-.25-.34-.16-.33-.1-.3-.04-.25-.02-.2.01-.13v-5.34l.05-.64.13-.54.21-.46.26-.38.3-.32.33-.24.35-.2.35-.14.33-.1.3-.06.26-.04.21-.02.13-.01h5.84l.69-.05.59-.14.5-.21.41-.28.33-.32.27-.35.2-.36.15-.36.1-.35.07-.32.04-.28.02-.21V6.07h2.09l.14.01zm-6.47 14.25l-.23.33-.08.41.08.41.23.33.33.23.41.08.41-.08.33-.23.23-.33.08-.41-.08-.41-.23-.33-.33-.23-.41-.08-.41.08z"/>
            </svg>
            Python SDK
          </a>
          <a href="/docs/cookbook" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] hover:border-[var(--color-border-default)] transition-colors">
            <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            Cookbooks
          </a>
        </div>
      </div>
    </section>

    <!-- Product Categories - Stripe inspired grid -->
    <section class="border-y border-[var(--color-border-subtle)] bg-[var(--color-bg-secondary)]/50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Evaluate -->
          <a href="/docs/evaluate" class="group relative p-6 rounded-xl bg-[var(--color-bg-primary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/40 transition-all hover:shadow-lg">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-1 group-hover:text-[var(--color-accent-primary)] transition-colors">
                  Evaluate
                </h3>
                <p class="text-sm text-[var(--color-text-tertiary)] mb-3">
                  70+ metrics for quality, safety, and RAG. Custom evaluators for any domain.
                </p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="px-2 py-0.5 text-xs rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400">Relevance</span>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400">Safety</span>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400">RAG</span>
                </div>
              </div>
            </div>
          </a>

          <!-- Observe -->
          <a href="/docs/tracing" class="group relative p-6 rounded-xl bg-[var(--color-bg-primary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/40 transition-all hover:shadow-lg">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-1 group-hover:text-[var(--color-accent-primary)] transition-colors">
                  Observe
                </h3>
                <p class="text-sm text-[var(--color-text-tertiary)] mb-3">
                  Real-time tracing, cost tracking, and latency monitoring for LLM apps.
                </p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="px-2 py-0.5 text-xs rounded-full bg-blue-500/10 text-blue-600 dark:text-blue-400">Tracing</span>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-blue-500/10 text-blue-600 dark:text-blue-400">Costs</span>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-blue-500/10 text-blue-600 dark:text-blue-400">Latency</span>
                </div>
              </div>
            </div>
          </a>

          <!-- Simulate -->
          <a href="/docs/simulate" class="group relative p-6 rounded-xl bg-[var(--color-bg-primary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/40 transition-all hover:shadow-lg">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-1 group-hover:text-[var(--color-accent-primary)] transition-colors">
                  Simulate
                </h3>
                <p class="text-sm text-[var(--color-text-tertiary)] mb-3">
                  Test with synthetic users and scenarios. Stress-test before deployment.
                </p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="px-2 py-0.5 text-xs rounded-full bg-purple-500/10 text-purple-600 dark:text-purple-400">Personas</span>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-purple-500/10 text-purple-600 dark:text-purple-400">Scenarios</span>
                </div>
              </div>
            </div>
          </a>

          <!-- Protect -->
          <a href="/docs/protect" class="group relative p-6 rounded-xl bg-[var(--color-bg-primary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/40 transition-all hover:shadow-lg">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-1 group-hover:text-[var(--color-accent-primary)] transition-colors">
                  Protect
                </h3>
                <p class="text-sm text-[var(--color-text-tertiary)] mb-3">
                  Guardrails for safe AI. PII detection, content filtering, prompt injection blocking.
                </p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="px-2 py-0.5 text-xs rounded-full bg-red-500/10 text-red-600 dark:text-red-400">Guardrails</span>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-red-500/10 text-red-600 dark:text-red-400">PII</span>
                </div>
              </div>
            </div>
          </a>

          <!-- Agent Compass -->
          <a href="/docs/agent-compass" class="group relative p-6 rounded-xl bg-[var(--color-bg-primary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/40 transition-all hover:shadow-lg">
            <div class="absolute top-4 right-4">
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-500/20">New</span>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-1 group-hover:text-[var(--color-accent-primary)] transition-colors">
                  Agent Compass
                </h3>
                <p class="text-sm text-[var(--color-text-tertiary)] mb-3">
                  Debug complex agent workflows. Visualize execution paths and identify bottlenecks.
                </p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="px-2 py-0.5 text-xs rounded-full bg-amber-500/10 text-amber-600 dark:text-amber-400">Debug</span>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-amber-500/10 text-amber-600 dark:text-amber-400">Agents</span>
                </div>
              </div>
            </div>
          </a>

          <!-- Integrations -->
          <a href="/docs/integrations" class="group relative p-6 rounded-xl bg-[var(--color-bg-primary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/40 transition-all hover:shadow-lg">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-cyan-500/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-[var(--color-text-primary)] mb-1 group-hover:text-[var(--color-accent-primary)] transition-colors">
                  Integrations
                </h3>
                <p class="text-sm text-[var(--color-text-tertiary)] mb-3">
                  30+ framework integrations. LangChain, LlamaIndex, OpenAI, and more.
                </p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="px-2 py-0.5 text-xs rounded-full bg-cyan-500/10 text-cyan-600 dark:text-cyan-400">30+</span>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-cyan-500/10 text-cyan-600 dark:text-cyan-400">1-line</span>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Code Example Section - Cloudflare inspired -->
    <section class="py-12 lg:py-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text-primary)] mb-4">
              Start evaluating in minutes
            </h2>
            <p class="text-[var(--color-text-secondary)] mb-6">
              Install the SDK, add your API key, and evaluate any LLM output with a single function call.
            </p>

            <!-- Install command -->
            <div class="mb-6">
              <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-[var(--color-bg-tertiary)] border border-[var(--color-border-subtle)] font-mono text-sm">
                <span class="text-[var(--color-text-muted)]">$</span>
                <span class="text-[var(--color-text-primary)]">pip install futureagi</span>
                <button class="ml-auto p-1 hover:bg-[var(--color-bg-hover)] rounded transition-colors" title="Copy">
                  <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </button>
              </div>
            </div>

            <ul class="space-y-3 mb-6">
              <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>70+ built-in evaluation templates</span>
              </li>
              <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Automatic tracing with decorators</span>
              </li>
              <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Framework integrations included</span>
              </li>
            </ul>

            <a href="/docs/quickstart" class="inline-flex items-center gap-2 text-[var(--color-accent-primary)] font-medium hover:underline">
              Read the quickstart guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>

          <!-- Code block -->
          <div class="relative">
            <div class="rounded-xl bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] overflow-hidden shadow-lg">
              <div class="flex items-center justify-between px-4 py-2.5 border-b border-[var(--color-border-subtle)] bg-[var(--color-bg-tertiary)]">
                <div class="flex items-center gap-2">
                  <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
                  <span class="ml-2 text-xs text-[var(--color-text-muted)]">evaluate.py</span>
                </div>
              </div>
              <pre class="p-4 text-sm overflow-x-auto"><code class="text-[var(--color-text-secondary)]" set:html={codeExample} /></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Popular Resources - Stripe style -->
    <section class="py-12 lg:py-16 border-t border-[var(--color-border-subtle)] bg-[var(--color-bg-secondary)]/30">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-semibold text-[var(--color-text-primary)] mb-6">
          Popular resources
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <a href="/docs/evaluation/builtin" class="group flex items-start gap-3 p-4 rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-bg-primary)] hover:border-[var(--color-accent-primary)]/40 transition-colors">
