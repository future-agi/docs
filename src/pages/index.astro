---
/**
 * Documentation Homepage
 * Based on research from Stripe, Twilio, Sentry:
 * - Hero with clear value prop and primary CTA
 * - SDK/Platform quick selector
 * - Visual feature cards for main sections
 * - Quick start code preview
 * - Integration showcase
 * - Popular resources
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const codeExample = `<span class="syntax-keyword">from</span> <span class="syntax-class">futureagi</span> <span class="syntax-keyword">import</span> FutureAGI

<span class="syntax-comment"># Initialize client</span>
client = <span class="syntax-class">FutureAGI</span>()

<span class="syntax-comment"># Evaluate any LLM output</span>
result = client.<span class="syntax-function">evaluate</span>(
    <span class="syntax-variable">input</span>=<span class="syntax-string">"What is the capital of France?"</span>,
    <span class="syntax-variable">output</span>=<span class="syntax-string">"The capital of France is Paris."</span>,
    <span class="syntax-variable">metrics</span>=[<span class="syntax-string">"relevance"</span>, <span class="syntax-string">"correctness"</span>]
)

<span class="syntax-keyword">print</span>(result.scores)
<span class="syntax-comment"># {'relevance': 0.95, 'correctness': 1.0}</span>`;
---

<BaseLayout title="Documentation | Future AGI" description="Complete documentation for Future AGI - the AI lifecycle platform for evaluating, observing, and optimizing LLM applications.">
  <Header />

  <main class="pt-14">
    <!-- Hero Section -->
    <section class="relative overflow-hidden border-b border-[var(--color-border-subtle)]">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent-primary)]/5 via-transparent to-[var(--color-accent-secondary)]/5"></div>
      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
        <div class="max-w-3xl">
          <div class="flex items-center gap-2 mb-4">
            <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-[var(--color-accent-primary)]/10 text-[var(--color-accent-primary)] border border-[var(--color-accent-primary)]/20">
              v2.0 Release
            </span>
            <span class="text-sm text-[var(--color-text-muted)]">New: Agent Compass for debugging</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-[var(--color-text-primary)] mb-4">
            Build reliable AI applications
          </h1>
          <p class="text-xl text-[var(--color-text-secondary)] mb-8 leading-relaxed">
            Future AGI is the complete platform for evaluating, observing, and optimizing your LLM applications. Ship with confidence using 70+ metrics, real-time tracing, and automated optimization.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/docs/quickstart" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium rounded-lg bg-[var(--color-accent-primary)] text-white hover:bg-[var(--color-accent-primary)]/90 transition-colors">
              Get Started
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="/docs/api" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium rounded-lg border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] transition-colors">
              API Reference
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- SDK Quick Selector -->
    <section class="border-b border-[var(--color-border-subtle)] bg-[var(--color-bg-secondary)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-wrap items-center gap-3">
          <span class="text-sm text-[var(--color-text-muted)]">Quick start:</span>
          <a href="/docs/quickstart" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:border-[var(--color-accent-primary)] transition-colors">
            <svg class="w-5 h-5 text-[#3776AB]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77l-.69.05-.59.14-.5.22-.41.27-.33.32-.27.35-.2.36-.15.37-.1.35-.07.32-.04.27-.02.21v3.06H3.17l-.21-.03-.28-.07-.32-.12-.35-.18-.36-.26-.36-.36-.35-.46-.32-.59-.28-.73-.21-.88-.14-1.05-.05-1.23.06-1.22.16-1.04.24-.87.32-.71.36-.57.4-.44.42-.33.42-.24.4-.16.36-.1.32-.05.24-.01h.16l.06.01h8.16v-.83H6.18l-.01-2.75-.02-.37.05-.34.11-.31.17-.28.25-.26.31-.23.38-.2.44-.18.51-.15.58-.12.64-.1.71-.06.77-.04.84-.02 1.27.05zm-6.3 1.98l-.23.33-.08.41.08.41.23.34.33.22.41.09.41-.09.33-.22.23-.34.08-.41-.08-.41-.23-.33-.33-.22-.41-.09-.41.09zm13.09 3.95l.28.06.32.12.35.18.36.27.36.35.35.47.32.59.28.73.21.88.14 1.04.05 1.23-.06 1.23-.16 1.04-.24.86-.32.71-.36.57-.4.45-.42.33-.42.24-.4.16-.36.09-.32.05-.24.02-.16-.01h-8.22v.82h5.84l.01 2.76.02.36-.05.34-.11.31-.17.29-.25.25-.31.24-.38.2-.44.17-.51.15-.58.13-.64.09-.71.07-.77.04-.84.01-1.27-.04-1.07-.14-.9-.2-.73-.25-.59-.3-.45-.33-.34-.34-.25-.34-.16-.33-.1-.3-.04-.25-.02-.2.01-.13v-5.34l.05-.64.13-.54.21-.46.26-.38.3-.32.33-.24.35-.2.35-.14.33-.1.3-.06.26-.04.21-.02.13-.01h5.84l.69-.05.59-.14.5-.21.41-.28.33-.32.27-.35.2-.36.15-.36.1-.35.07-.32.04-.28.02-.21V6.07h2.09l.14.01zm-6.47 14.25l-.23.33-.08.41.08.41.23.33.33.23.41.08.41-.08.33-.23.23-.33.08-.41-.08-.41-.23-.33-.33-.23-.41-.08-.41.08z"/>
            </svg>
            Python
          </a>
          <a href="/docs/integrations/langchain" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:border-[var(--color-accent-primary)] transition-colors">
            <span class="text-lg">🦜</span>
            LangChain
          </a>
          <a href="/docs/integrations/llamaindex" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:border-[var(--color-accent-primary)] transition-colors">
            <span class="text-lg">🦙</span>
            LlamaIndex
          </a>
          <a href="/docs/integrations/openai" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:border-[var(--color-accent-primary)] transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/>
            </svg>
            OpenAI
          </a>
          <a href="/docs/api" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] text-[var(--color-text-primary)] hover:border-[var(--color-accent-primary)] transition-colors">
            <svg class="w-5 h-5 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            REST API
          </a>
        </div>
      </div>
    </section>

    <!-- Main Features Grid -->
    <section class="py-16 lg:py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text-primary)] mb-4">
            Everything you need to ship AI with confidence
          </h2>
          <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
            From evaluation to production monitoring, Future AGI provides the complete toolkit for building reliable AI applications.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Evaluate -->
          <a href="/docs/evaluate" class="group relative p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/50 transition-all hover:shadow-lg hover:shadow-[var(--color-accent-primary)]/5">
            <div class="w-12 h-12 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 icon-emerald" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-accent-primary)] transition-colors">
              Evaluate
            </h3>
            <p class="text-sm text-[var(--color-text-tertiary)] mb-4">
              70+ built-in metrics for quality, safety, and RAG performance. Create custom evaluators for your domain.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">Relevance</span>
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">Safety</span>
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">RAG</span>
            </div>
          </a>

          <!-- Observe -->
          <a href="/docs/observe" class="group relative p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/50 transition-all hover:shadow-lg hover:shadow-[var(--color-accent-primary)]/5">
            <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 icon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 12h-4l-3 9L9 3l-3 9H2" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-accent-primary)] transition-colors">
              Observe
            </h3>
            <p class="text-sm text-[var(--color-text-tertiary)] mb-4">
              Real-time tracing, cost tracking, and latency monitoring. Debug complex agent workflows with Agent Compass.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">Tracing</span>
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">Costs</span>
              <span class="px-2 py-1 text-xs rounded bg-blue-500/10 icon-blue">New</span>
            </div>
          </a>

          <!-- Optimize -->
          <a href="/docs/optimize" class="group relative p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/50 transition-all hover:shadow-lg hover:shadow-[var(--color-accent-primary)]/5">
            <div class="w-12 h-12 rounded-lg bg-amber-500/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 icon-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-accent-primary)] transition-colors">
              Optimize
            </h3>
            <p class="text-sm text-[var(--color-text-tertiary)] mb-4">
              Automated prompt engineering with Bayesian optimization. Run structured experiments and A/B tests.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">Prompts</span>
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">Experiments</span>
            </div>
          </a>

          <!-- Protect -->
          <a href="/docs/protect" class="group relative p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/50 transition-all hover:shadow-lg hover:shadow-[var(--color-accent-primary)]/5">
            <div class="w-12 h-12 rounded-lg bg-red-500/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 icon-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-accent-primary)] transition-colors">
              Protect
            </h3>
            <p class="text-sm text-[var(--color-text-tertiary)] mb-4">
              Guardrails for safe AI. Detect PII, filter harmful content, and block prompt injection attacks.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">Guardrails</span>
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">PII</span>
            </div>
          </a>

          <!-- Simulate -->
          <a href="/docs/simulate" class="group relative p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/50 transition-all hover:shadow-lg hover:shadow-[var(--color-accent-primary)]/5">
            <div class="w-12 h-12 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 icon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-accent-primary)] transition-colors">
              Simulate
            </h3>
            <p class="text-sm text-[var(--color-text-tertiary)] mb-4">
              Test with synthetic users and diverse scenarios. Stress-test agents before deployment.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">Personas</span>
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">Scenarios</span>
            </div>
          </a>

          <!-- Integrations -->
          <a href="/docs/integrations" class="group relative p-6 rounded-xl bg-[var(--color-bg-secondary)] border border-[var(--color-border-subtle)] hover:border-[var(--color-accent-primary)]/50 transition-all hover:shadow-lg hover:shadow-[var(--color-accent-primary)]/5">
            <div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 icon-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-accent-primary)] transition-colors">
              Integrations
            </h3>
            <p class="text-sm text-[var(--color-text-tertiary)] mb-4">
              Connect with 30+ frameworks. LangChain, LlamaIndex, OpenAI, Anthropic, and more.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">30+</span>
              <span class="px-2 py-1 text-xs rounded bg-[var(--color-bg-tertiary)] text-[var(--color-text-muted)]">1-line setup</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Code Preview Section -->
    <section class="py-16 lg:py-20 bg-[var(--color-bg-secondary)] border-y border-[var(--color-border-subtle)]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text-primary)] mb-4">
              Get started in minutes
            </h2>
            <p class="text-lg text-[var(--color-text-secondary)] mb-6">
              Install the SDK, set your API key, and start evaluating LLM outputs with just a few lines of code.
            </p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                <svg class="w-5 h-5 icon-emerald flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>One-line installation</span>
              </li>
              <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                <svg class="w-5 h-5 icon-emerald flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Auto-tracing with decorators</span>
              </li>
              <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                <svg class="w-5 h-5 icon-emerald flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Framework integrations included</span>
              </li>
            </ul>
            <a href="/docs/quickstart" class="inline-flex items-center gap-2 text-[var(--color-accent-primary)] font-medium hover:underline">
              Read the quickstart guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
          <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-r from-[var(--color-accent-primary)]/10 to-[var(--color-accent-secondary)]/10 rounded-2xl blur-xl"></div>
            <div class="relative rounded-xl bg-[var(--color-bg-primary)] border border-[var(--color-border-default)] overflow-hidden">
              <div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--color-border-subtle)] bg-[var(--color-bg-tertiary)]">
                <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
