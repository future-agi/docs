{
  "openapi": "3.0.0",
  "info": {
    "title": "Future AGI API Reference",
    "version": "1.0.0",
    "description": "Complete API documentation for Future AGI, including health checks, authentication, user management, workspaces, organizations, and API keys",
    "contact": {
      "email": "support@futureagi.com"
    }
  },
  "servers": [
    {
      "url": "https://api.futureagi.com",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health check operations for monitoring server status"
    },
    {
      "name": "Authentication",
      "description": "User authentication and token management"
    },
    {
      "name": "User Management",
      "description": "User signup, profile, and account management"
    },
    {
      "name": "Workspaces",
      "description": "Workspace creation and management"
    },
    {
      "name": "Team Management",
      "description": "Team member and role management"
    },
    {
      "name": "Organizations",
      "description": "Organization selection and switching"
    },
    {
      "name": "API Keys",
      "description": "API key and secret key management"
    }
  ],
  "paths": {
    "/health/": {
      "get": {
        "summary": "Health check",
        "description": "Returns 200 status when server is up and running. No authentication required.",
        "operationId": "healthCheck",
        "tags": ["Health"],
        "security": [],
        "responses": {
          "200": {
            "description": "Server is healthy and running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "description": "Status of the request",
                      "example": true
                    },
                    "result": {
                      "type": "string",
                      "description": "Health status message",
                      "example": "Server is up and running"
                    }
                  },
                  "required": ["status", "result"]
                },
                "examples": {
                  "success": {
                    "summary": "Successful health check",
                    "value": {
                      "status": true,
                      "result": "Server is up and running"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Internal server error"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/token/": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Obtain JWT token",
        "description": "Authenticate user and obtain access and refresh tokens",
        "operationId": "tokenObtainPair",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "User email address",
                    "example": "user@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "description": "User password",
                    "example": "password123"
                  },
                  "rememberMe": {
                    "type": "boolean",
                    "description": "Remember user session",
                    "default": false
                  },
                  "organizationId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Optional organization ID for direct login"
                  },
                  "recaptchaResponse": {
                    "type": "string",
                    "description": "reCAPTCHA verification token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access": {
                      "type": "string",
                      "description": "Access token (encrypted)"
                    },
                    "refresh": {
                      "type": "string",
                      "description": "Refresh token (encrypted)"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid credentials or blocked account",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "error": {
                          "type": "string",
                          "example": "Invalid credentials"
                        },
                        "remainingAttempts": {
                          "type": "integer",
                          "example": 3
                        }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "error": {
                          "type": "string",
                          "example": "Account temporarily blocked. Please try again in 45 minutes."
                        },
                        "blocked": {
                          "type": "boolean",
                          "example": true
                        },
                        "blockTimeRemaining": {
                          "type": "integer",
                          "example": 2700
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/accounts/token/refresh/": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Refresh JWT token",
        "description": "Get a new access token using refresh token",
        "operationId": "tokenRefresh",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh"],
                "properties": {
                  "refresh": {
                    "type": "string",
                    "description": "Encrypted refresh token"
                  },
                  "recaptchaResponse": {
                    "type": "string",
                    "description": "reCAPTCHA verification token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New access token generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access": {
                      "type": "string",
                      "description": "New access token"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired refresh token"
          }
        }
      }
    },
    "/accounts/signup/": {
      "post": {
        "tags": ["User Management"],
        "summary": "User signup",
        "description": "Create a new user account",
        "operationId": "userSignup",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "fullName"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "newuser@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "minLength": 8
                  },
                  "fullName": {
                    "type": "string",
                    "example": "John Doe"
                  },
                  "organizationName": {
                    "type": "string",
                    "example": "My Company"
                  },
                  "recaptchaResponse": {
                    "type": "string",
                    "description": "reCAPTCHA verification token"
                  },
                  "allowEmail": {
                    "type": "boolean",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully"
          },
          "400": {
            "description": "Invalid input or user already exists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "User with this email already exists."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
