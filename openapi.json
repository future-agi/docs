              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "email": {
                      "type": "string",
                      "format": "email"
                    },
                    "fullName": {
                      "type": "string"
                    },
                    "rememberMe": {
                      "type": "boolean"
                    },
                    "wsEnabled": {
                      "type": "boolean"
                    },
                    "getStartedCompleted": {
                      "type": "boolean"
                    },
                    "organization": {
                      "type": "object"
                    },
                    "workspaces": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
